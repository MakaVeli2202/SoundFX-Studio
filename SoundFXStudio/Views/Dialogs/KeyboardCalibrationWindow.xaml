<Window x:Class="SoundFXStudio.Views.Dialogs.KeyboardCalibrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SoundFXStudio.Controls"
        Title="Keyboard Cluster Calibration"
        Width="1440"
        Height="980"
        WindowStartupLocation="CenterScreen"
        Background="#050505"
        WindowStyle="None"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Icon="/Assets/SoundFXStudioLogo.png">

    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#0D0D0D" />
        <SolidColorBrush x:Key="SecondaryPanelBrush" Color="#141414" />
        <SolidColorBrush x:Key="BorderBrushTheme" Color="#252525" />
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="MutedBrush" Color="#9D9D9D" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#191919" />
            <Setter Property="BorderBrush" Value="#303030" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#252525" />
                    <Setter Property="BorderBrush" Value="#22D3FF" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#22D3FF" />
                    <Setter Property="Foreground" Value="#050505" />
                    <Setter Property="BorderBrush" Value="#22D3FF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#131313" />
            <Setter Property="BorderBrush" Value="#303030" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
        </Style>

        <Style x:Key="StepperButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#141414" />
            <Setter Property="BorderBrush" Value="#303030" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
        </Style>

        <Style TargetType="ToolTip">
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Background" Value="#121212" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Border Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushTheme}"
                BorderThickness="1"
                CornerRadius="20"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="46"
                                Height="46"
                                CornerRadius="12"
                                Background="#0A0A0A"
                                BorderBrush="#303030"
                                BorderThickness="1"
                                Padding="4"
                                Margin="0,0,12,0">
                            <Image Source="/Assets/SoundFXStudioLogo.png" Stretch="Uniform" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="SoundFX Studio" Foreground="{StaticResource MutedBrush}" FontSize="13" FontWeight="Bold" />
                            <TextBlock Text="Cluster Calibration" FontSize="26" FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="✕"
                            Width="40"
                            Height="30"
                            VerticalAlignment="Top"
                            Background="#2A1118"
                            BorderBrush="#5F2336"
                            Click="CloseButton_Click" />
                </Grid>

                <Grid Grid.Row="1" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="440" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Background="{StaticResource SecondaryPanelBrush}"
                                    BorderBrush="{StaticResource BorderBrushTheme}"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Padding="16"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Global Alignment" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />

                                    <TextBlock Text="Quick Presets" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                                    <WrapPanel Margin="0,0,0,12">
                                    <Button Content="Factory"
                                        Margin="0,0,8,8"
                                        Click="PresetFactory_Click" />
                                    <Button Content="Centered"
                                        Margin="0,0,8,8"
                                        Click="PresetCentered_Click" />
                                    <Button Content="Tight"
                                        Margin="0,0,8,8"
                                        Click="PresetTight_Click" />
                                    </WrapPanel>

                                    <TextBlock Text="Key Unit" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4" />
                                    <DockPanel Margin="0,0,0,10">
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                            <Button Style="{StaticResource StepperButtonStyle}"
                                                Content="≪"
                                                Tag="PreviewKeyUnit:-5"
                                                Click="NudgeValue_Click" />
                                            <Button Style="{StaticResource StepperButtonStyle}"
                                                Content="◀"
                                                Tag="PreviewKeyUnit:-1"
                                                Click="NudgeValue_Click" />
                                            <TextBox Width="88"
                                                 Margin="6,0"
                                                 Text="{Binding PreviewKeyUnit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button Style="{StaticResource StepperButtonStyle}"
                                                Content="▶"
                                                Tag="PreviewKeyUnit:1"
                                                Click="NudgeValue_Click" />
                                            <Button Style="{StaticResource StepperButtonStyle}"
                                                Content="≫"
                                                Tag="PreviewKeyUnit:5"
                                                Click="NudgeValue_Click" />
                                        </StackPanel>
                                        <Slider Minimum="-120"
                                                Maximum="120"
                                                Value="{Binding PreviewKeyUnit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                TickFrequency="1"
                                                Margin="0,0,10,0" />
                                    </DockPanel>

                                    <TextBlock Text="Gap" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4" />
                                    <DockPanel Margin="0,0,0,10">
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                            <Button Style="{StaticResource StepperButtonStyle}"
                                                Content="≪"
                                                Tag="PreviewGap:-2"
                                                Click="NudgeValue_Click" />
                                            <Button Style="{StaticResource StepperButtonStyle}"
                                                Content="◀"
                                                Tag="PreviewGap:-0.5"
                                                Click="NudgeValue_Click" />
                                            <TextBox Width="88"
                                                 Margin="6,0"
                                                 Text="{Binding PreviewGap, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button Style="{StaticResource StepperButtonStyle}"
                                                Content="▶"
                                                Tag="PreviewGap:0.5"
                                                Click="NudgeValue_Click" />
                                            <Button Style="{StaticResource StepperButtonStyle}"
                                                Content="≫"
                                                Tag="PreviewGap:2"
                                                Click="NudgeValue_Click" />
                                        </StackPanel>
                                        <Slider Minimum="-80"
                                                Maximum="80"
                                                Value="{Binding PreviewGap, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                TickFrequency="0.5"
                                                Margin="0,0,10,0" />
                                    </DockPanel>

                                    <TextBlock Text="Offset X" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4" />
                                    <DockPanel Margin="0,0,0,10">
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                            <Button Style="{StaticResource StepperButtonStyle}"
                                                Content="≪"
                                                Tag="PreviewOffsetX:-10"
                                                Click="NudgeValue_Click" />
                                            <Button Style="{StaticResource StepperButtonStyle}"
                                                Content="◀"
                                                Tag="PreviewOffsetX:-1"
                                                Click="NudgeValue_Click" />
                                            <TextBox Width="88"
                                                 Margin="6,0"
                                                 Text="{Binding PreviewOffsetX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button Style="{StaticResource StepperButtonStyle}"
                                                Content="▶"
                                                Tag="PreviewOffsetX:1"
                                                Click="NudgeValue_Click" />
                                            <Button Style="{StaticResource StepperButtonStyle}"
                                                Content="≫"
                                                Tag="PreviewOffsetX:10"
                                                Click="NudgeValue_Click" />
                                        </StackPanel>
                                        <Slider Minimum="-500"
                                            Maximum="500"
                                                Value="{Binding PreviewOffsetX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                TickFrequency="1"
                                                Margin="0,0,10,0" />
                                    </DockPanel>

                                    <TextBlock Text="Offset Y" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4" />
                                    <DockPanel>
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                            <Button Style="{StaticResource StepperButtonStyle}"
                                                Content="≪"
                                                Tag="PreviewOffsetY:-10"
                                                Click="NudgeValue_Click" />
                                            <Button Style="{StaticResource StepperButtonStyle}"
                                                Content="◀"
                                                Tag="PreviewOffsetY:-1"
                                                Click="NudgeValue_Click" />
                                            <TextBox Width="88"
                                                 Margin="6,0"
                                                 Text="{Binding PreviewOffsetY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button Style="{StaticResource StepperButtonStyle}"
                                                Content="▶"
                                                Tag="PreviewOffsetY:1"
                                                Click="NudgeValue_Click" />
                                            <Button Style="{StaticResource StepperButtonStyle}"
                                                Content="≫"
                                                Tag="PreviewOffsetY:10"
                                                Click="NudgeValue_Click" />
                                        </StackPanel>
                                        <Slider Minimum="-500"
                                                Maximum="500"
                                                Value="{Binding PreviewOffsetY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                TickFrequency="1"
                                                Margin="0,0,10,0" />
                                    </DockPanel>

                                    <TextBlock Text="Button Scale" Foreground="{StaticResource MutedBrush}" Margin="0,12,0,4" />
                                    <DockPanel>
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                            <Button Style="{StaticResource StepperButtonStyle}"
                                                Content="≪"
                                                Tag="PreviewButtonScale:-0.1"
                                                Click="NudgeValue_Click" />
                                            <Button Style="{StaticResource StepperButtonStyle}"
                                                Content="◀"
                                                Tag="PreviewButtonScale:-0.01"
                                                Click="NudgeValue_Click" />
                                            <TextBox Width="88"
                                                 Margin="6,0"
                                                 Text="{Binding PreviewButtonScale, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button Style="{StaticResource StepperButtonStyle}"
                                                Content="▶"
                                                Tag="PreviewButtonScale:0.01"
                                                Click="NudgeValue_Click" />
                                            <Button Style="{StaticResource StepperButtonStyle}"
                                                Content="≫"
                                                Tag="PreviewButtonScale:0.1"
                                                Click="NudgeValue_Click" />
                                        </StackPanel>
                                        <Slider Minimum="-2"
                                                Maximum="2"
                                                Value="{Binding PreviewButtonScale, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                TickFrequency="0.01"
                                                Margin="0,0,10,0" />
                                    </DockPanel>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource SecondaryPanelBrush}"
                                    BorderBrush="{StaticResource BorderBrushTheme}"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Cluster Offsets" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />
                                    <TextBlock Text="If a normal key looks wrong, fix the cluster offset instead." TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,12" />

                                    <ItemsControl ItemsSource="{Binding ClusterItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#2B2B2B"
                                                        BorderThickness="1"
                                                        CornerRadius="12"
                                                        Padding="10"
                                                        Margin="0,0,0,10">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontWeight="SemiBold"
                                                                   Margin="0,0,0,8" />

                                                        <Grid Margin="0,0,0,6">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="22" />
                                                                <ColumnDefinition Width="30" />
                                                            <ColumnDefinition Width="30" />
                                                                <ColumnDefinition Width="70" />
                                                                <ColumnDefinition Width="30" />
                                                            <ColumnDefinition Width="30" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="X"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="{StaticResource MutedBrush}" />
                                                            <Button Grid.Column="1"
                                                                    Style="{StaticResource StepperButtonStyle}"
                                                                Content="≪"
                                                                Tag="OffsetX:-5"
                                                                Click="NudgeValue_Click" />
                                                            <Button Grid.Column="2"
                                                                Style="{StaticResource StepperButtonStyle}"
                                                                    Content="◀"
                                                                    Tag="OffsetX:-1"
                                                                    Click="NudgeValue_Click" />
                                                            <TextBox Grid.Column="3"
                                                                     Margin="6,0"
                                                                     Text="{Binding OffsetX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                            <Button Grid.Column="4"
                                                                    Style="{StaticResource StepperButtonStyle}"
                                                                    Content="▶"
                                                                    Tag="OffsetX:1"
                                                                    Click="NudgeValue_Click" />
                                                            <Button Grid.Column="5"
                                                                Style="{StaticResource StepperButtonStyle}"
                                                                Content="≫"
                                                                Tag="OffsetX:5"
                                                                Click="NudgeValue_Click" />
                                                        </Grid>

                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="22" />
                                                                <ColumnDefinition Width="30" />
                                                            <ColumnDefinition Width="30" />
                                                                <ColumnDefinition Width="70" />
                                                                <ColumnDefinition Width="30" />
                                                            <ColumnDefinition Width="30" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="Y"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="{StaticResource MutedBrush}" />
                                                            <Button Grid.Column="1"
                                                                    Style="{StaticResource StepperButtonStyle}"
                                                                Content="≪"
                                                                Tag="OffsetY:-5"
                                                                Click="NudgeValue_Click" />
                                                            <Button Grid.Column="2"
                                                                Style="{StaticResource StepperButtonStyle}"
                                                                Content="◀"
                                                                    Tag="OffsetY:-1"
                                                                    Click="NudgeValue_Click" />
                                                            <TextBox Grid.Column="3"
                                                                     Margin="6,0"
                                                                     Text="{Binding OffsetY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                            <Button Grid.Column="4"
                                                                    Style="{StaticResource StepperButtonStyle}"
                                                                Content="▶"
                                                                    Tag="OffsetY:1"
                                                                Click="NudgeValue_Click" />
                                                            <Button Grid.Column="5"
                                                                Style="{StaticResource StepperButtonStyle}"
                                                                Content="≫"
                                                                Tag="OffsetY:5"
                                                                    Click="NudgeValue_Click" />
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource SecondaryPanelBrush}"
                                    BorderBrush="{StaticResource BorderBrushTheme}"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Padding="16"
                                    Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="Special Keys" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />
                                    <TextBlock Text="Width overrides only. No normal-key coordinates." TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" />
                                    <CheckBox Content="Show debug borders"
                                              IsChecked="{Binding DebugCalibration, Mode=TwoWay}"
                                              Margin="0,12,0,0" />

                                    <ItemsControl ItemsSource="{Binding SpecialItems}" Margin="0,12,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#2B2B2B"
                                                        BorderThickness="1"
                                                        CornerRadius="12"
                                                        Padding="10"
                                                        Margin="0,0,0,10">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="180" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontWeight="SemiBold"
                                                                   VerticalAlignment="Center" />
                                                        <StackPanel Grid.Column="1" Margin="8,0,0,0" Orientation="Horizontal">
                                                            <Button Style="{StaticResource StepperButtonStyle}"
                                                                Content="≪"
                                                                Tag="WidthAdjustment:-0.25"
                                                                Click="NudgeValue_Click" />
                                                            <Button Style="{StaticResource StepperButtonStyle}"
                                                                    Content="◀"
                                                                    Tag="WidthAdjustment:-0.1"
                                                                    Click="NudgeValue_Click" />
                                                            <TextBox Width="88"
                                                                     Margin="6,0"
                                                                     Text="{Binding WidthAdjustment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                            <Button Style="{StaticResource StepperButtonStyle}"
                                                                    Content="▶"
                                                                    Tag="WidthAdjustment:0.1"
                                                                    Click="NudgeValue_Click" />
                                                            <Button Style="{StaticResource StepperButtonStyle}"
                                                                Content="≫"
                                                                Tag="WidthAdjustment:0.25"
                                                                Click="NudgeValue_Click" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Button Content="Reset All"
                                            Margin="0,4,0,0"
                                            Click="ResetAll_Click" />
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource SecondaryPanelBrush}"
                                    BorderBrush="{StaticResource BorderBrushTheme}"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Padding="16"
                                    Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="Per-Key Overrides" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />
                                    <TextBlock Text="Pick any key and adjust it freely." Foreground="{StaticResource MutedBrush}" Margin="0,0,0,10" />

                                    <ComboBox ItemsSource="{Binding KeyItems}"
                                              DisplayMemberPath="Name"
                                              SelectedItem="{Binding SelectedKeyItem, Mode=TwoWay}" />

                                    <StackPanel DataContext="{Binding SelectedKeyItem}" Margin="0,10,0,0">
                                        <TextBlock Text="Offset X" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4" />
                                        <DockPanel Margin="0,0,0,8">
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                <Button Style="{StaticResource StepperButtonStyle}" Content="◀" Tag="OffsetX:-1" Click="NudgeValue_Click" />
                                                <TextBox Width="88" Margin="6,0" Text="{Binding OffsetX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <Button Style="{StaticResource StepperButtonStyle}" Content="▶" Tag="OffsetX:1" Click="NudgeValue_Click" />
                                            </StackPanel>
                                        </DockPanel>

                                        <TextBlock Text="Offset Y" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4" />
                                        <DockPanel Margin="0,0,0,8">
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                <Button Style="{StaticResource StepperButtonStyle}" Content="◀" Tag="OffsetY:-1" Click="NudgeValue_Click" />
                                                <TextBox Width="88" Margin="6,0" Text="{Binding OffsetY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <Button Style="{StaticResource StepperButtonStyle}" Content="▶" Tag="OffsetY:1" Click="NudgeValue_Click" />
                                            </StackPanel>
                                        </DockPanel>

                                        <TextBlock Text="Width Adjustment" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4" />
                                        <DockPanel Margin="0,0,0,8">
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                <Button Style="{StaticResource StepperButtonStyle}" Content="◀" Tag="WidthAdjustment:-0.1" Click="NudgeValue_Click" />
                                                <TextBox Width="88" Margin="6,0" Text="{Binding WidthAdjustment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <Button Style="{StaticResource StepperButtonStyle}" Content="▶" Tag="WidthAdjustment:0.1" Click="NudgeValue_Click" />
                                            </StackPanel>
                                        </DockPanel>

                                        <TextBlock Text="Height Adjustment" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4" />
                                        <DockPanel>
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                <Button Style="{StaticResource StepperButtonStyle}" Content="◀" Tag="HeightAdjustment:-0.1" Click="NudgeValue_Click" />
                                                <TextBox Width="88" Margin="6,0" Text="{Binding HeightAdjustment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <Button Style="{StaticResource StepperButtonStyle}" Content="▶" Tag="HeightAdjustment:0.1" Click="NudgeValue_Click" />
                                            </StackPanel>
                                        </DockPanel>

                                        <Button Content="Reset Selected Key"
                                                Margin="0,10,0,0"
                                                Click="ResetSelectedKey_Click" />
                                    </StackPanel>

                                        <TextBlock Text="Per-Key JSON (Code)"
                                               FontWeight="SemiBold"
                                               Margin="0,12,0,6" />
                                        <TextBlock Text="Format: keyId -> offsetX, offsetY, widthAdjustment, heightAdjustment"
                                               Foreground="{StaticResource MutedBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,6" />
                                        <TextBox Height="180"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             FontFamily="Consolas"
                                             Text="{Binding PerKeyOverridesJson, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <Button Content="Apply JSON"
                                            Margin="0,0,8,0"
                                            Click="ApplyPerKeyJson_Click" />
                                        <Button Content="Revert JSON"
                                            Click="RevertPerKeyJson_Click" />
                                        </StackPanel>

                                        <TextBlock Text="{Binding JsonEditorStatus}"
                                               Foreground="{StaticResource MutedBrush}"
                                               Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Column="2"
                            Background="{StaticResource SecondaryPanelBrush}"
                            BorderBrush="{StaticResource BorderBrushTheme}"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Live Preview" FontSize="18" FontWeight="Bold" />
                                <TextBlock Text="  Changes redraw immediately" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" />
                            </StackPanel>

                            <Border Grid.Row="1"
                                    Background="#090909"
                                    BorderBrush="#202020"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Padding="12">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Auto">
                                    <Viewbox Stretch="Uniform">
                                        <controls:KeyboardControl x:Name="PreviewKeyboard"
                                                                  ItemsSource="{Binding KeyboardKeys}"
                                                                  ButtonScale="{Binding PreviewButtonScale}"
                                                                  KeyClickedCommand="{Binding KeyClickedCommand}" />
                                    </Viewbox>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                    <TextBlock Text="Tune global geometry first. Then move the clusters, not individual letters." Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,16,0" />
                    <Button Content="Load Project JSON"
                        Width="140"
                        Margin="0,0,8,0"
                        Click="LoadFromJsonFile_Click" />
                    <Button Content="Save Permanently"
                            Width="150"
                            Margin="0,0,8,0"
                            Click="SavePermanently_Click" />
                    <Button Content="Close" Width="110" Click="CloseButton_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>