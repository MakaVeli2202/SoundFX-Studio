<Window x:Class="SoundFXStudio.Views.Dialogs.SoundAssignmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Sound"
        Height="680"
        Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="/Assets/SoundFXStudioLogo.png">


    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#101A2D" />
        <SolidColorBrush x:Key="SecondaryPanelBrush" Color="#0E1728" />
        <SolidColorBrush x:Key="BorderBrushTheme" Color="#2E4568" />
        <SolidColorBrush x:Key="TextBrush" Color="#EAF1FF" />
        <SolidColorBrush x:Key="MutedBrush" Color="#A4B2C9" />
    </Window.Resources>

    <Grid Margin="20" ClipToBounds="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource SecondaryPanelBrush}"
                BorderBrush="#2E4568"
                BorderThickness="1"
                CornerRadius="16"
                Padding="12"
                Margin="0,0,0,14">
            <Grid MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="42"
                            Height="42"
                            CornerRadius="12"
                            Background="#0A0A0A"
                            BorderBrush="#303030"
                            BorderThickness="1"
                            Padding="4"
                            Margin="0,0,12,0">
                        <Image Source="/Assets/SoundFXStudioLogo.png" Stretch="Uniform" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="SoundFX Studio" FontSize="13" FontWeight="Bold" Foreground="{StaticResource MutedBrush}" />
                        <TextBlock Text="Sound Details" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="✕"
                    AutomationProperties.Name="Close"
                        Width="40"
                        Height="30"
                        VerticalAlignment="Top"
                        Background="#3C1B2A"
                        BorderBrush="#7B3C57"
                        Click="CloseButton_Click" />
            </Grid>
        </Border>

        <TextBlock Grid.Row="0"
                   Text="Pick a file, name, image, shortcut, and options before saving"
                   Foreground="{StaticResource MutedBrush}"
                   Margin="0,54,0,14" />

        <Border Grid.Row="1"
                Background="{StaticResource SecondaryPanelBrush}"
                BorderBrush="{StaticResource BorderBrushTheme}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="16">
            <ScrollViewer>
                <StackPanel>
                    <!-- File Selection -->
                    <Border Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Sound File" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />
                            <TextBlock Text="Pick an audio file (MP3, WAV, OGG, FLAC)" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,10" />
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                
                                <TextBox x:Name="FilePathBox" 
                                         AutomationProperties.Name="Sound File Path"
                                         IsReadOnly="True" 
                                         Text="{Binding FilePath, Mode=OneWay}"
                                         Height="34" 
                                         Padding="10,6"
                                         Background="{StaticResource PanelBrush}"
                                         BorderBrush="{StaticResource BorderBrushTheme}"
                                         BorderThickness="1"
                                         Foreground="{StaticResource TextBrush}"
                                         Margin="0,0,10,0"/>
                                
                                <Button x:Name="BrowseButton" 
                                    AutomationProperties.Name="Browse"
                                    AutomationProperties.AutomationId="BrowseButton"
                                        Content="Browse" 
                                        Width="100" 
                                    Height="34"
                                        Grid.Column="1"
                                        Click="BrowseButton_Click"
                                        Background="#5AD8FF"
                                        Foreground="#08101D"
                                        FontWeight="Bold" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Display Name -->
                    <StackPanel Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Sound Name" FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
                            <TextBlock Text="(label on keyboard button)" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="8,2,0,0" />
                        </StackPanel>
                        <TextBox x:Name="NameBox"
                                 AutomationProperties.Name="Sound Name"
                                 Text="{Binding Name}"
                                 Height="36"
                                 Padding="10,6"
                                 Background="{StaticResource PanelBrush}"
                                 BorderBrush="{StaticResource BorderBrushTheme}"
                                 BorderThickness="1"
                                 Foreground="{StaticResource TextBrush}" />
                    </StackPanel>

                    <!-- Keyboard Button Selection -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Keyboard Button" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6" />
                        <ComboBox ItemsSource="{Binding AvailableKeys}"
                                  AutomationProperties.Name="Keyboard Button"
                                  DisplayMemberPath="DisplayLabel"
                                  SelectedValuePath="Id"
                                  SelectedValue="{Binding SelectedKey}"
                                  Height="36"
                                  Padding="10,6"
                                  Background="{StaticResource PanelBrush}"
                                  BorderBrush="{StaticResource BorderBrushTheme}"
                                  BorderThickness="1"
                                  Foreground="{StaticResource TextBrush}" />
                    </StackPanel>

                    <!-- Category -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Sound Group" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6" />
                        <ComboBox ItemsSource="{Binding Categories}"
                                  AutomationProperties.Name="Sound Group"
                                  SelectedItem="{Binding Category}"
                                  Height="36"
                                  Padding="10,6"
                                  Background="{StaticResource PanelBrush}"
                                  BorderBrush="{StaticResource BorderBrushTheme}"
                                  BorderThickness="1"
                                  Foreground="{StaticResource TextBrush}" />
                    </StackPanel>

                    <!-- Volume -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Volume" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="50" />
                            </Grid.ColumnDefinitions>
                            <Slider Minimum="0"
                                    AutomationProperties.Name="Volume"
                                    AutomationProperties.AutomationId="VolumeSlider"
                                    Maximum="100"
                                    Value="{Binding VolumePercent}"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center"
                                    Foreground="#36D1FF" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding VolumePercent, StringFormat='0%'}"
                                       Foreground="{StaticResource MutedBrush}"
                                       VerticalAlignment="Center"
                                       TextAlignment="Right" />
                        </Grid>
                    </StackPanel>

                    <!-- Options -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Options" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,10" />
                        <CheckBox Content="Mark as favorite (⭐ icon)"
                                  AutomationProperties.Name="Favorite"
                                  IsChecked="{Binding IsFavorite}"
                                  Foreground="{StaticResource TextBrush}"
                                  Margin="0,0,0,8" />
                        <CheckBox Content="Loop sound continuously"
                                  AutomationProperties.Name="Loop"
                                  IsChecked="{Binding Loop}"
                                  Foreground="{StaticResource TextBrush}" />
                    </StackPanel>

                    <!-- Image Selection -->
                    <Border Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="12">
                        <StackPanel>
                            <TextBlock Text="Custom Image (Optional)" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,10" />
                            
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                
                                <TextBox x:Name="ImagePathBox" 
                                         AutomationProperties.Name="Image File Path"
                                         IsReadOnly="True" 
                                         Text="{Binding ImagePath, Mode=OneWay}"
                                         Height="34"
                                         Padding="10,6"
                                         Background="{StaticResource SecondaryPanelBrush}"
                                         BorderBrush="{StaticResource BorderBrushTheme}"
                                         BorderThickness="1"
                                         Foreground="{StaticResource TextBrush}" />
                                
                                <Button x:Name="ImageBrowseButton" 
                                    AutomationProperties.Name="Choose"
                                    AutomationProperties.AutomationId="ImageBrowseButton"
                                        Content="Choose" 
                                        Width="90" 
                                    Height="34"
                                        Grid.Column="1"
                                        Margin="10,0,0,0"
                                        Click="ImageBrowseButton_Click"
                                        Background="#5AD8FF"
                                        Foreground="#08101D"
                                        FontWeight="Bold" />
                            </Grid>
                            
                            <!-- Image Preview -->
                            <Border x:Name="ImagePreviewBorder"
                                    Background="{StaticResource PanelBrush}"
                                    CornerRadius="8"
                                    Height="120"
                                    BorderBrush="{StaticResource BorderBrushTheme}"
                                    BorderThickness="1">
                                <Image x:Name="ImagePreview"
                                       Source="{Binding ImagePath, Mode=OneWay}"
                                       Stretch="UniformToFill" />
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                Margin="0,14,0,0">
            <Button Content="Cancel"
                    AutomationProperties.Name="Cancel"
                    AutomationProperties.AutomationId="CancelButton"
                    Width="100"
                    Margin="0,0,10,0"
                    Click="CancelButton_Click"
                    Background="#2A3D5D"
                    Foreground="{StaticResource TextBrush}" />
            <Button Content="Save"
                    AutomationProperties.Name="Save"
                    AutomationProperties.AutomationId="SaveButton"
                    Width="100"
                    Click="SaveButton_Click"
                    Background="#5AD8FF"
                    Foreground="#08101D"
                    FontWeight="Bold" />
        </StackPanel>
    </Grid>
</Window>