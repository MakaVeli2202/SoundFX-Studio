<Window x:Class="SoundFXStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SoundFXStudio.Controls"
        Title="SoundFX Studio"
        Width="1600"
        Height="920"
        MinWidth="1280"
        MinHeight="760"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Icon="/Assets/SoundFXStudioLogo.png">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#050505" />
        <SolidColorBrush x:Key="PanelBrush" Color="#0D0D0D" />
        <SolidColorBrush x:Key="SecondaryPanelBrush" Color="#141414" />
        <SolidColorBrush x:Key="KeyboardSurfaceBrush" Color="#090909" />
        <SolidColorBrush x:Key="BorderBrushTheme" Color="#252525" />
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#9D9D9D" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#191919" />
            <Setter Property="BorderBrush" Value="#303030" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#252525" />
                    <Setter Property="BorderBrush" Value="#36D1FF" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#36D1FF" />
                    <Setter Property="Foreground" Value="#000000" />
                    <Setter Property="BorderBrush" Value="#36D1FF" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#666666" />
                    <Setter Property="Background" Value="#0F0F0F" />
                    <Setter Property="BorderBrush" Value="#1A1A1A" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#131313" />
            <Setter Property="BorderBrush" Value="#303030" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#141414" />
            <Setter Property="BorderBrush" Value="#303030" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#141414" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#22D3FF" />
                    <Setter Property="Foreground" Value="#050505" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF4D8D" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListView">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#101010" />
            <Setter Property="BorderBrush" Value="#303030" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#101010" />
            <Setter Property="Padding" Value="4" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#22D3FF" />
                    <Setter Property="Foreground" Value="#050505" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#111111" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushTheme}" />
            <Setter Property="Padding" Value="16,9" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#22D3FF" />
                    <Setter Property="BorderBrush" Value="#22D3FF" />
                    <Setter Property="Foreground" Value="#050505" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A1A1A" />
                    <Setter Property="BorderBrush" Value="#22D3FF" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

        <Grid Margin="0"
                    Background="Transparent"
                    PreviewMouseLeftButtonDown="WindowShell_PreviewMouseLeftButtonDown">
        <Border Background="Transparent"
                BorderThickness="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Background="{StaticResource SecondaryPanelBrush}"
                        CornerRadius="0"
                        BorderBrush="{StaticResource BorderBrushTheme}"
                        BorderThickness="0,0,0,1"
                        Padding="16,12">
                    <Grid MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="54"
                                    Height="54"
                                    CornerRadius="14"
                                    Background="#0A0A0A"
                                    BorderBrush="#303030"
                                    BorderThickness="1"
                                    Padding="5"
                                    Margin="0,0,14,0">
                                <Image Source="{StaticResource SoundFXLogo}" Stretch="Uniform" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="SoundFX Studio" FontSize="28" FontWeight="Bold" />
                                <TextBlock Text="Make Audio Magical" Foreground="{StaticResource SecondaryTextBrush}" FontSize="13" Margin="0,2,0,0" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                                <Button Content="_" Width="40" Height="30" Margin="0,0,8,0" Click="MinimizeButton_Click" />
                                <Button Content="☐" Width="40" Height="30" Margin="0,0,8,0" Click="MaximizeRestoreButton_Click" />
                                <Button Content="✕" Width="40" Height="30" Background="#2A1118" BorderBrush="#5F2336" Click="CloseButton_Click" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Border Background="#181818"
                                        BorderBrush="#303030"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="10,6"
                                        Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Language" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource SecondaryTextBrush}" />
                                        <ComboBox Width="150"
                                                  SelectedItem="{Binding KeyboardLayout, Mode=TwoWay}"
                                                  ItemsSource="{Binding KeyboardLayoutOptions}" />
                                    </StackPanel>
                                </Border>

                                <ComboBox Width="140"
                                          Margin="0,0,12,0"
                                          ItemsSource="{Binding ThemeOptions}"
                                          SelectedItem="{Binding SelectedTheme, Mode=TwoWay}" />

                                <Button Content="Save"
                                    Width="96"
                                    Height="38"
                                        Command="{Binding SaveCommand}"
                                        Margin="0,0,10,0" />
                                <Button Content="Refresh"
                                    Width="96"
                                    Height="38"
                                        Command="{Binding RefreshCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <TabControl Grid.Row="1"
                            Margin="16,12,16,16"
                            SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrushTheme}"
                            BorderThickness="1">
                    <TabItem Header="Keyboard">
                        <Border Background="{StaticResource KeyboardSurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrushTheme}"
                                BorderThickness="1"
                                CornerRadius="20"
                                Padding="10"
                                Margin="6">
                            <Viewbox Stretch="Uniform"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <controls:KeyboardControl ItemsSource="{Binding KeyboardKeys}"
                                                          KeyClickedCommand="{Binding KeyClickedCommand}" />
                            </Viewbox>
                        </Border>
                    </TabItem>

                    <TabItem Header="Routing">
                        <Grid Margin="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="0.9*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Audio Routing Dashboard" FontSize="24" FontWeight="Bold" Margin="0,0,0,6" />
                                <TextBlock Text="Pick the devices your sounds and microphone should use. The setup wizard writes the same state on first run." Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,0,0,12" />

                                <UniformGrid Columns="3" Margin="0,0,0,12">
                                    <Border Background="#0B1320" CornerRadius="16" Padding="12" Margin="0,0,10,0">
                                        <StackPanel>
                                            <TextBlock Text="Output" Foreground="{StaticResource SecondaryTextBrush}" />
                                            <TextBlock Text="{Binding CurrentOutputDevice}" FontSize="18" FontWeight="Bold" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#0B1320" CornerRadius="16" Padding="12" Margin="0,0,10,0">
                                        <StackPanel>
                                            <TextBlock Text="Input" Foreground="{StaticResource SecondaryTextBrush}" />
                                            <TextBlock Text="{Binding CurrentInputDevice}" FontSize="18" FontWeight="Bold" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#0B1320" CornerRadius="16" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="Preset" Foreground="{StaticResource SecondaryTextBrush}" />
                                            <TextBlock Text="{Binding CurrentPreset}" FontSize="18" FontWeight="Bold" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <Border Background="#111111" BorderBrush="#2C2C2C" BorderThickness="1" CornerRadius="18" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="Routing path" FontSize="18" FontWeight="Bold" Margin="0,0,0,6" />
                                        <TextBlock Text="{Binding RoutingStatus}" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,0,0,8" />
                                        <StackPanel Orientation="Horizontal">
                                            <Border Background="#151515" CornerRadius="10" Padding="10,6" Margin="0,0,8,0">
                                                <TextBlock Text="Sounds → Output" Foreground="{StaticResource TextBrush}" />
                                            </Border>
                                            <Border Background="#151515" CornerRadius="10" Padding="10,6" Margin="0,0,8,0">
                                                <TextBlock Text="Mic → Input" Foreground="{StaticResource TextBrush}" />
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="Control Panel" FontSize="20" FontWeight="Bold" Margin="0,0,0,8" />

                                <TextBlock Text="Output device" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                <ComboBox ItemsSource="{Binding OutputDevices}"
                                          DisplayMemberPath="Name"
                                          SelectedValuePath="Id"
                                          SelectedValue="{Binding Settings.OutputDeviceId, Mode=TwoWay}"
                                          Margin="0,0,0,10" />

                                <TextBlock Text="Input device" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                <ComboBox ItemsSource="{Binding InputDevices}"
                                          DisplayMemberPath="Name"
                                          SelectedValuePath="Id"
                                          SelectedValue="{Binding Settings.InputDeviceId, Mode=TwoWay}"
                                          Margin="0,0,0,10" />

                                <Button Content="Auto-configure audio"
                                        Command="{Binding AutoConfigureAudioCommand}"
                                        Margin="0,0,0,8" />
                                <Button Content="Test routing"
                                    Command="{Binding TestRoutingCommand}"
                                    Margin="0,0,0,8" />
                                <Button Content="Open setup wizard"
                                        Command="{Binding OpenSetupWizardCommand}"
                                        Margin="0,0,0,8" />
                                <Button Content="Open Windows Sound"
                                        Click="MainWindow_OpenSoundSettings" />
                            </StackPanel>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Library">
                        <Grid Margin="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="340" />
                            </Grid.ColumnDefinitions>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBox Width="240"
                                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Search sounds" />
                                    <ComboBox Width="160"
                                              Margin="10,0,0,0"
                                              ItemsSource="{Binding Categories}"
                                              DisplayMemberPath="Name"
                                              SelectedValuePath="Name"
                                              SelectedValue="{Binding SelectedCategoryFilter, Mode=TwoWay}" />
                                    <CheckBox Content="Favorites only"
                                              IsChecked="{Binding FavoritesOnly, Mode=TwoWay}"
                                              VerticalAlignment="Center"
                                              Margin="12,0,0,0" />
                                </StackPanel>

                                <StackPanel Grid.Row="1">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Border Background="#151515" CornerRadius="10" Padding="6">
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="➕ Add" Command="{Binding AddSoundCommand}" ToolTip="Add a new sound to the library (Ctrl+N)" />
                                                <Button Content="📁 Import" Command="{Binding AddMultipleSoundsCommand}" Margin="6,0,0,0" ToolTip="Import multiple sounds at once" />
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#151515" CornerRadius="10" Padding="6" Margin="10,0,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="▶️ Play" Command="{Binding PlaySelectedSoundCommand}" ToolTip="Play selected sound (Space)" />
                                                <Button Content="❤️ Fav" Command="{Binding ToggleFavoriteCommand}" Margin="6,0,0,0" ToolTip="Toggle favorite status" />
                                                <Button Content="🗑️ Delete" Command="{Binding DeleteSoundCommand}" Margin="6,0,0,0" ToolTip="Delete sound from library" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <TextBlock Name="EmptyLibraryMessage" Text="📭 No sounds added yet. Click ➕ Add to get started." Foreground="{StaticResource SecondaryTextBrush}" FontSize="14" TextAlignment="Center" Margin="0,60,0,0" Visibility="{Binding SoundsView.Count, Converter={StaticResource EmptyToVisibilityConverter}}" />
                                    <ListView ItemsSource="{Binding SoundsView}"
                                              SelectedItem="{Binding SelectedSound}"
                                              Name="SoundsListView"
                                              Visibility="{Binding SoundsView.Count, Converter={StaticResource NonEmptyToVisibilityConverter}}">
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                                                <Setter Property="ContextMenu">
                                                    <Setter.Value>
                                                        <ContextMenu>
                                                            <MenuItem Header="✏️ Edit Sound"
                                                                      Command="{Binding DataContext.EditSoundCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                                      CommandParameter="{Binding}" />
                                                            <Separator />
                                                            <MenuItem Header="📝 Rename Sound"
                                                                      Command="{Binding DataContext.RenameSoundCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                                      CommandParameter="{Binding}" />
                                                            <MenuItem Header="🖼️ Set Image"
                                                                      Command="{Binding DataContext.ChooseSoundImageCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                                      CommandParameter="{Binding}" />
                                                            <MenuItem Header="⌨️ Set Shortcut"
                                                                      Command="{Binding DataContext.SetSoundHotkeyCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                                      CommandParameter="{Binding}" />
                                                            <Separator />
                                                            <MenuItem Header="▶️ Play"
                                                                      Command="{Binding DataContext.PlaySoundCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                                      CommandParameter="{Binding}" />
                                                        </ContextMenu>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="280" />
                                                <GridViewColumn Header="Category" DisplayMemberBinding="{Binding Category}" Width="130" />
                                                <GridViewColumn Header="Shortcut" DisplayMemberBinding="{Binding Hotkey}" Width="120" />
                                                <GridViewColumn Header="★" DisplayMemberBinding="{Binding IsFavorite}" Width="40" />
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </StackPanel>
                            </Grid>

                            <Border Grid.Column="1"
                                    Margin="10,0,0,0"
                                    Background="#0B1320"
                                    CornerRadius="18"
                                    Padding="14">
                                <StackPanel>
                                    <TextBlock Text="Preview" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />
                                    <Border Height="160" Background="#111A2D" CornerRadius="14" Margin="0,0,0,10">
                                        <Grid>
                                            <Image Source="{Binding SelectedSound.ImagePath}" Stretch="UniformToFill" Opacity="0.45" />
                                            <TextBlock Text="{Binding SelectedSound.Name}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                    <TextBlock Text="{Binding SelectedSound.Category}" Opacity="0.78" />
                                    <TextBlock Text="{Binding SelectedSound.Hotkey}" Opacity="0.78" />
                                    <TextBlock Text="{Binding SelectedSound.PlayCount, StringFormat=Plays: {0}}" Opacity="0.78" />
                                    <TextBlock Text="{Binding StatusText}" Margin="0,12,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Settings">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="6">
                                <TextBlock Text="General" FontSize="18" FontWeight="Bold" Margin="0,0,0,6" />
                                <CheckBox Content="Enable keyboard shortcuts globally" IsChecked="{Binding Settings.EnableGlobalHotkeys, Mode=TwoWay}" Margin="0,0,0,6" />
                                <CheckBox Content="Start minimized" IsChecked="{Binding Settings.StartMinimized, Mode=TwoWay}" Margin="0,0,0,6" />
                                <CheckBox Content="Allow multiple instances" IsChecked="{Binding Settings.AllowMultipleInstances, Mode=TwoWay}" Margin="0,0,0,6" />

                                <TextBlock Text="Appearance" FontSize="18" FontWeight="Bold" Margin="0,10,0,6" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Theme" Width="160" VerticalAlignment="Center" />
                                    <ComboBox Width="180"
                                              ItemsSource="{Binding ThemeOptions}"
                                              SelectedItem="{Binding SelectedTheme, Mode=TwoWay}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Keyboard layout" Width="160" VerticalAlignment="Center" />
                                    <ComboBox Width="180"
                                              ItemsSource="{Binding KeyboardLayoutOptions}"
                                              SelectedItem="{Binding KeyboardLayout, Mode=TwoWay}" />
                                </StackPanel>

                                <TextBlock Text="Audio Devices" FontSize="18" FontWeight="Bold" Margin="0,10,0,6" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Output" Width="160" VerticalAlignment="Center" />
                                    <ComboBox Width="360"
                                              ItemsSource="{Binding OutputDevices}"
                                              DisplayMemberPath="Name"
                                              SelectedValuePath="Id"
                                              SelectedValue="{Binding Settings.OutputDeviceId, Mode=TwoWay}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Input" Width="160" VerticalAlignment="Center" />
                                    <ComboBox Width="360"
                                              ItemsSource="{Binding InputDevices}"
                                              DisplayMemberPath="Name"
                                              SelectedValuePath="Id"
                                              SelectedValue="{Binding Settings.InputDeviceId, Mode=TwoWay}" />
                                </StackPanel>
                                <Button Content="Auto-configure audio"
                                    Width="180"
                                    Margin="160,4,0,0"
                                    HorizontalAlignment="Left"
                                    Command="{Binding AutoConfigureAudioCommand}" />

                                <TextBlock Text="Keyboard Shortcuts" FontSize="18" FontWeight="Bold" Margin="0,10,0,6" />
                                <TextBlock Text="Press F1-F12 to trigger sounds from anywhere. Right-click keyboard buttons to customize shortcuts." TextWrapping="Wrap" Opacity="0.78" Margin="0,0,0,6" />

                                <TextBlock Text="Presets" FontSize="18" FontWeight="Bold" Margin="0,10,0,6" />
                                <TextBlock Text="Create multiple setups and switch between them instantly. Each preset saves different sounds and assignments." TextWrapping="Wrap" Opacity="0.78" Margin="0,0,0,6" />

                                <TextBlock Text="Advanced" FontSize="18" FontWeight="Bold" Margin="0,10,0,6" />
                                <TextBlock Text="Storage is file-based under AppData. Future effects, voice tools, and cloud sync can hook into the same model and config services." TextWrapping="Wrap" Opacity="0.78" Margin="0,0,0,6" />

                                <TextBlock Text="Storage" FontSize="18" FontWeight="Bold" Margin="0,10,0,6" />
                                <TextBlock Text="Config, sounds, and images are stored under the app data folder managed by ConfigService." TextWrapping="Wrap" Opacity="0.78" />
                                <Button Content="Open Audio Setup Wizard"
                                        Width="200"
                                        Margin="0,14,0,0"
                                        Command="{Binding OpenSetupWizardCommand}" />
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Presets">
                        <Grid Margin="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="360" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBox Width="220"
                                             Text="{Binding ProfileSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Search profiles" />
                                    <Button Content="New"
                                            Command="{Binding CreateProfileCommand}"
                                            Margin="10,0,0,0" />
                                </StackPanel>

                                <ListBox ItemsSource="{Binding ProfilesView}"
                                         SelectedItem="{Binding SelectedProfile}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#355275"
                                                    BorderThickness="1"
                                                        CornerRadius="10"
                                                        Padding="8"
                                                        Margin="0,0,0,6">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" />
                                                    <TextBlock Text="{Binding Description}" Opacity="0.72" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Margin="10,0,0,0"
                                    Background="#0B1320"
                                    CornerRadius="18"
                                    Padding="14">
                                <StackPanel>
                                    <TextBlock Text="Current Setup" FontSize="18" FontWeight="Bold" Margin="0,0,0,6" />
                                    <TextBlock Text="{Binding SelectedProfile.Name}" FontSize="16" />
                                    <TextBlock Text="{Binding StatusText}" Opacity="0.8" Margin="0,6,0,12" />
                                    <TextBlock Text="All your sounds and keyboard assignments are stored in this preset." TextWrapping="Wrap" Opacity="0.78" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Statistics">
                        <Grid Margin="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Most Played" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" />
                                <ListBox ItemsSource="{Binding MostPlayedSounds}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" />
                                                <TextBlock Text="{Binding PlayCount, StringFormat=Plays: {0}}" Opacity="0.72" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Text="Recent" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" />
                                <ListBox ItemsSource="{Binding RecentSounds}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" />
                                                <TextBlock Text="{Binding LastPlayedUtc}" Opacity="0.72" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="12,0,0,0">
                                <TextBlock Text="Favorites" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" />
                                <ListBox ItemsSource="{Binding FavoriteSounds}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" />
                                                <TextBlock Text="{Binding Category}" Opacity="0.72" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>
    </Grid>
</Window>