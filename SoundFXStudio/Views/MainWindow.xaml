<Window x:Class="SoundFXStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SoundFXStudio.Controls"
        xmlns:converters="clr-namespace:SoundFXStudio.Converters"
        Title="SoundFX Studio"
       
Width="1536"
Height="1024"

        MinWidth="1280"
        MinHeight="760"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Icon="/Assets/SoundFXStudioLogo.png">

    <Window.Resources>

        <SolidColorBrush x:Key="WindowBrush"
                         Color="#050A15"/>

        <SolidColorBrush x:Key="PanelBrush"
                         Color="#0A1222"/>

        <SolidColorBrush x:Key="PanelBrushAlt"
                         Color="#0F1830"/>

        <SolidColorBrush x:Key="TextBrush"
                         Color="#EAF1FF"/>

        <SolidColorBrush x:Key="SecondaryTextBrush"
                         Color="#A1B2D2"/>

        <Style x:Key="SidebarButton" TargetType="Button">

            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="65"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Background" Value="#22112233"/>
            <Setter Property="BorderBrush" Value="#3370AFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>


            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="Border"
                        CornerRadius="14"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">

        <Grid PreviewMouseLeftButtonDown="WindowShell_PreviewMouseLeftButtonDown">

                                <Rectangle Fill="#08FFFFFF"
                                   RadiusX="14"
                                   RadiusY="14"/>

                                <ContentPresenter HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  Margin="22,0,0,0"/>

                            </Grid>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                             Value="True">

                                <Setter TargetName="Border"
                                Property="BorderBrush"
                                Value="#00D8FF"/>

                                <Setter TargetName="Border"
                                Property="Background"
                                Value="#331A2948"/>

                            </Trigger>

                            <Trigger Property="IsPressed"
                             Value="True">

                                <Setter TargetName="Border"
                                Property="Background"
                                Value="#552A4580"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

        <Style x:Key="NeonButton"
       TargetType="Button">

            <Setter Property="Foreground"
            Value="White"/>

            <Setter Property="FontWeight"
            Value="Bold"/>

            <Setter Property="FontSize"
            Value="18"/>

            <Setter Property="Height"
            Value="60"/>

            <Setter Property="Cursor"
            Value="Hand"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border CornerRadius="16">

                            <Border.Background>

                                <LinearGradientBrush StartPoint="0,0"
                                             EndPoint="1,0">

                                    <GradientStop Color="#00BFFF"
                                          Offset="0"/>

                                    <GradientStop Color="#AA45FF"
                                          Offset="1"/>

                                </LinearGradientBrush>

                            </Border.Background>

                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>

                        </Border>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

        <Style x:Key="GlassPanel" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Background" Value="#66081428"/>
            <Setter Property="BorderBrush" Value="#5580CFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="GlassComboBox" TargetType="ComboBox">

            <Setter Property="Foreground" Value="White"/>

            <Setter Property="FontSize" Value="14"/>

            <Setter Property="Background" Value="#44111A2E"/>

            <Setter Property="BorderBrush" Value="#5580CFFF"/>

            <Setter Property="BorderThickness" Value="1"/>

            <Setter Property="Padding" Value="10,4"/>

        </Style>

        <Style x:Key="WindowControlButtonStyle" TargetType="Button">

            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#22112233"/>
            <Setter Property="BorderBrush" Value="#3370AFFF"/>
            <Setter Property="BorderThickness" Value="1"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="Border"
                        CornerRadius="10"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">

                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">

                                <Setter TargetName="Border"
                                        Property="Background"
                                        Value="#1100D8FF"/>

                                <Setter TargetName="Border"
                                        Property="BorderBrush"
                                        Value="#00D8FF"/>

                                <Setter TargetName="Border"
                                        Property="BorderThickness"
                                        Value="1"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

        <Style x:Key="HeroOverlayButton"
       TargetType="Button">

            <Setter Property="Background"
            Value="Transparent"/>

            <Setter Property="BorderThickness"
            Value="0"/>

            <Setter Property="Cursor"
            Value="Hand"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="HoverBorder"
                        CornerRadius="10"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0">

                            <ContentPresenter/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                             Value="True">

                                <Setter TargetName="HoverBorder"
                                Property="Background"
                                Value="#1100D8FF"/>

                                <Setter TargetName="HoverBorder"
                                Property="BorderBrush"
                                Value="#33AAFFFF"/>

                                <Setter TargetName="HoverBorder"
                                Property="BorderThickness"
                                Value="1"/>

                            </Trigger>

                            <Trigger Property="IsPressed"
                             Value="True">

                                <Setter TargetName="HoverBorder"
                                Property="Background"
                                Value="#22FF44CC"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

        <Style x:Key="WindowControlButton"
       TargetType="Button">

            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Foreground" Value="#EAF1FF"/>
            <Setter Property="Background" Value="#15000000"/>
            <Setter Property="BorderBrush" Value="#336AAEFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="ChromeBorder"
                        CornerRadius="12"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">

                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                             Value="True">

                                <Setter TargetName="ChromeBorder"
                                Property="BorderBrush"
                                Value="#00D8FF"/>

                                <Setter TargetName="ChromeBorder"
                                Property="Background"
                                Value="#2200D8FF"/>

                            </Trigger>

                            <Trigger Property="IsPressed"
                             Value="True">

                                <Setter TargetName="ChromeBorder"
                                Property="Background"
                                Value="#4400D8FF"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

        <Style x:Key="CloseWindowButton"
       BasedOn="{StaticResource WindowControlButton}"
       TargetType="Button">

            <Setter Property="Background"
            Value="#331E0E12"/>

            <Setter Property="BorderBrush"
            Value="#AAFF4D6D"/>

        </Style>

    </Window.Resources>

    <Border Margin="8"
        CornerRadius="20"
        Background="#070E18">

        <Border.Effect>
            <DropShadowEffect BlurRadius="50"
                          ShadowDepth="0"
                          Color="#000000"
                          Opacity="0.6"/>
        </Border.Effect>

        <Border.BorderBrush>

            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,0">

                <GradientStop Color="#00D8FF"
                              Offset="0"/>

                <GradientStop Color="#FF44CC"
                              Offset="1"/>

            </LinearGradientBrush>

        </Border.BorderBrush>

        <Border.BorderThickness>2</Border.BorderThickness>

        <Grid>

            <!-- Dashboard Skin -->
            <Image Source="/Assets/UI/MainWindowBackground.png" Stretch="Fill"/>

            <!-- Dashboard Logo -->


            <Image Source="/Assets/UI/MainDashboardLogo.png"
                   Width="310"
                   Height="110"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                   Margin="55,45,0,0">
                <Image.Style>
                    <Style TargetType="Image">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentPage}" Value="Home">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Image.Style>
            </Image>

            <!-- Dashboard Hero Section -->
            <!-- HERO PANEL -->

            <Border Width="1100"
                    Height="600"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="370,180,0,0">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource GlassPanel}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentPage}" Value="Home">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>

                    <Image Source="/Assets/UI/HeroSection.png"
                           Stretch="Uniform"
                           Margin="20"/>

                    <!-- Open Keyboard Overlay -->
                    <Button Style="{StaticResource HeroOverlayButton}"
                            Width="275"
                            Height="54"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Margin="52,-15,0,0"
                            Click="OpenKeyboardWindowButton_Click"/>



                </Grid>

            </Border>

            <!-- Sound Library Page -->
            <Border Width="1100"
                    Height="600"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="370,180,0,0">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource GlassPanel}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentPage}" Value="SoundLibrary">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="SOUND LIBRARY"
                               Foreground="#00D8FF"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,0,0,16"/>

                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,12,0"/>

                        <Button Grid.Column="1"
                                Content="Add Sound"
                                Command="{Binding AddSoundCommand}"
                                Width="120"
                                Height="36"
                                Margin="0,0,12,0"/>

                        <Button Grid.Column="2"
                                Content="Delete"
                                Command="{Binding DeleteMarkedSoundsCommand}"
                                Width="90"
                                Height="36"/>
                    </Grid>

                    <ListView Grid.Row="2"
                              ItemsSource="{Binding SoundsView}"
                              Background="Transparent"
                              BorderThickness="0">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="280"/>
                                <GridViewColumn Header="Category" DisplayMemberBinding="{Binding Category}" Width="160"/>
                                <GridViewColumn Header="Plays" DisplayMemberBinding="{Binding PlayCount}" Width="80"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>

            <!-- Mixer Page -->
            <Border Width="1100"
                    Height="600"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="370,180,0,0">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource GlassPanel}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentPage}" Value="Mixer">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="30">

                        <TextBlock Text="MIXER"
                                   Foreground="#00D8FF"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="Output Device"
                                   Foreground="#A1B2D2"
                                   FontSize="14"
                                   Margin="0,0,0,6"/>

                        <TextBlock Text="{Binding CurrentOutputDevice}"
                                   Foreground="#DDEAFF"
                                   FontSize="16"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="Input Device"
                                   Foreground="#A1B2D2"
                                   FontSize="14"
                                   Margin="0,0,0,6"/>

                        <TextBlock Text="{Binding CurrentInputDevice}"
                                   Foreground="#DDEAFF"
                                   FontSize="16"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="{Binding RoutingStatus}"
                                   Foreground="#A1B2D2"
                                   FontSize="13"
                                   Margin="0,0,0,24"/>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Auto Configure"
                                    Command="{Binding AutoConfigureAudioCommand}"
                                    Width="150"
                                    Height="40"
                                    Margin="0,0,12,0"/>

                            <Button Content="Test Routing"
                                    Command="{Binding TestRoutingCommand}"
                                    Width="150"
                                    Height="40"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Effects Page -->
            <Border Width="1100"
                    Height="600"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="370,180,0,0">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource GlassPanel}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentPage}" Value="Effects">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <TextBlock Text="EFFECTS"
                               Foreground="#00D8FF"
                               FontSize="24"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,-40,0,0"/>
                    <TextBlock Text="Coming Soon"
                               Foreground="#A1B2D2"
                               FontSize="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,20,0,0"/>
                </Grid>
            </Border>

            <!-- Analytics Page -->
            <Border Width="1100"
                    Height="600"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="370,180,0,0">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource GlassPanel}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentPage}" Value="Analytics">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="30">

                        <TextBlock Text="ANALYTICS"
                                   Foreground="#00D8FF"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="Most Played"
                                   Foreground="#DDEAFF"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>

                        <ItemsControl ItemsSource="{Binding MostPlayedSounds}"
                                      Margin="0,0,0,24">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="#A1B2D2"
                                               Padding="4,3"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Recent"
                                   Foreground="#DDEAFF"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>

                        <ItemsControl ItemsSource="{Binding RecentSounds}"
                                      Margin="0,0,0,24">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="#A1B2D2"
                                               Padding="4,3"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Favorites"
                                   Foreground="#DDEAFF"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>

                        <ItemsControl ItemsSource="{Binding FavoriteSounds}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="#A1B2D2"
                                               Padding="4,3"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Settings Page -->
            <Border Width="1100"
                    Height="600"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="370,180,0,0">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource GlassPanel}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentPage}" Value="Settings">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="30">

                        <TextBlock Text="SETTINGS"
                                   Foreground="#00D8FF"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="Theme"
                                   Foreground="#A1B2D2"
                                   FontSize="14"
                                   Margin="0,0,0,6"/>

                        <ComboBox ItemsSource="{Binding ThemeOptions}"
                                  SelectedItem="{Binding SelectedTheme}"
                                  Width="200"
                                  HorizontalAlignment="Left"
                                  Margin="0,0,0,20"/>

                        <TextBlock Text="Keyboard Layout"
                                   Foreground="#A1B2D2"
                                   FontSize="14"
                                   Margin="0,0,0,6"/>

                        <ComboBox ItemsSource="{Binding KeyboardLayoutOptions}"
                                  SelectedItem="{Binding KeyboardLayout}"
                                  Width="200"
                                  HorizontalAlignment="Left"
                                  Margin="0,0,0,20"/>

                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="#A1B2D2"
                                   FontSize="13"
                                   Margin="0,20,0,0"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>


            <!-- Top Header Controls -->

            <ComboBox Width="180"
                      Height="40"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top"
                      Margin="810,50,0,0"
                      ItemsSource="{Binding KeyboardLayoutOptions}"
                      SelectedItem="{Binding KeyboardLayout}">
                <ComboBox.Style>
                    <Style TargetType="ComboBox" BasedOn="{StaticResource GlassComboBox}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentPage}" Value="Home">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ComboBox.Style>
            </ComboBox>

            <ComboBox Width="180"
                      Height="40"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top"
                      Margin="1010,50,0,0"
                      ItemsSource="{Binding ThemeOptions}"
                      SelectedItem="{Binding SelectedTheme}">
                <ComboBox.Style>
                    <Style TargetType="ComboBox" BasedOn="{StaticResource GlassComboBox}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentPage}" Value="Home">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ComboBox.Style>
            </ComboBox>

            <Button Width="130"
                    Height="40"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="1180,50,0,0"
                    Content="Calibration"
                    Click="OpenCalibrationButton_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentPage}" Value="Home">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Title Bar -->

            <Border HorizontalAlignment="Stretch"
                    Height="56"
                    VerticalAlignment="Top"
                    Margin="0,-18,0,0"
                    CornerRadius="20,20,0,0"
                    Background="#22081428"
                    BorderBrush="#5500D8FF"
                    BorderThickness="0,0,0,1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18"
                          ShadowDepth="0"
                          Color="#00D8FF"
                          Opacity="0.25"/>
                </Border.Effect>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,8,12,0">
                    <Button Style="{StaticResource WindowControlButtonStyle}"
                            Width="36"
                            Height="36"
                            Content="−"
                            FontSize="18"
                            Click="MinimizeButton_Click"
                            Margin="0,0,8,0"/>
                    <Button Style="{StaticResource CloseWindowButton}"
                            Width="40"
                            Height="40"
                            Content="✕"
                            Click="CloseButton_Click"/>
                </StackPanel>
            </Border>



            <!-- Sidebar -->

            <Border Style="{StaticResource GlassPanel}"
                    Width="300"
                    Height="620"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="45,180,0,0">

                <StackPanel Margin="20">

                    <Button Click="NavigateHome_Click">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="Home">
                                        <Setter Property="Background" Value="#3300D8FF"/>
                                        <Setter Property="BorderBrush" Value="#00D8FF"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏠" Foreground="#00D8FF" Margin="0,0,12,0"/>
                            <TextBlock Text="Home" Foreground="#DDEAFF"/>
                        </StackPanel>
                    </Button>

                    <Button Click="NavigateKeyboard_Click">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="Keyboard">
                                        <Setter Property="Background" Value="#3300D8FF"/>
                                        <Setter Property="BorderBrush" Value="#00D8FF"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⌨" Foreground="#00D8FF" Margin="0,0,12,0"/>
                            <TextBlock Text="Keyboard" Foreground="#DDEAFF"/>
                        </StackPanel>
                    </Button>

                    <Button Click="NavigateMixer_Click">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="Mixer">
                                        <Setter Property="Background" Value="#3300D8FF"/>
                                        <Setter Property="BorderBrush" Value="#00D8FF"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎛" Foreground="#00D8FF" Margin="0,0,12,0"/>
                            <TextBlock Text="Mixer" Foreground="#DDEAFF"/>
                        </StackPanel>
                    </Button>

                    <Button Click="NavigateSoundLibrary_Click">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="SoundLibrary">
                                        <Setter Property="Background" Value="#3300D8FF"/>
                                        <Setter Property="BorderBrush" Value="#00D8FF"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
