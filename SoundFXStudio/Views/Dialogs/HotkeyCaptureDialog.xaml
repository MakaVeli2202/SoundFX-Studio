<Window x:Class="SoundFXStudio.Views.Dialogs.HotkeyCaptureDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Capture Hotkey"
        Width="520"
        Height="320"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        Loaded="Window_Loaded"
        PreviewKeyDown="Window_PreviewKeyDown"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>

        <Style x:Key="GlassPanel"
               TargetType="Border">

            <Setter Property="CornerRadius"
                    Value="24"/>

            <Setter Property="Background"
                    Value="#66081428"/>

            <Setter Property="BorderBrush"
                    Value="#5580CFFF"/>

            <Setter Property="BorderThickness"
                    Value="1"/>

        </Style>

        <Style x:Key="GlassButton"
               TargetType="Button">

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="Background"
                    Value="#22112233"/>

            <Setter Property="BorderBrush"
                    Value="#3370AFFF"/>

            <Setter Property="BorderThickness"
                    Value="1"/>

            <Setter Property="Cursor"
                    Value="Hand"/>

            <Setter Property="Height"
                    Value="40"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="ButtonBorder"
                                CornerRadius="14"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">

                                <Setter TargetName="ButtonBorder"
                                        Property="BorderBrush"
                                        Value="#00D8FF"/>

                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#2200D8FF"/>

                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">

                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#33FF44CC"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

    </Window.Resources>

    <Border Background="#081428"
            CornerRadius="28"
            ClipToBounds="True">

        <Border.BorderBrush>

            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,0">

                <GradientStop Color="#00D8FF"
                              Offset="0"/>

                <GradientStop Color="#FF44CC"
                              Offset="1"/>

            </LinearGradientBrush>

        </Border.BorderBrush>

        <Border.BorderThickness>2</Border.BorderThickness>

        <Grid Margin="18">

            <Grid.RowDefinitions>

                <RowDefinition Height="75"/>

                <RowDefinition Height="*"/>

                <RowDefinition Height="70"/>

            </Grid.RowDefinitions>

            <!-- HEADER -->

            <Border Grid.Row="0"
                    Style="{StaticResource GlassPanel}">

                <Grid>

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="*"/>

                        <ColumnDefinition Width="Auto"/>

                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="18,0">

                        <Image Source="/Assets/SoundFXStudioLogo.png"
                               Width="46"
                               Height="46"/>

                        <StackPanel Margin="12,0,0,0">

                            <TextBlock Text="SOUNDFX STUDIO"
                                       Foreground="#00D8FF"
                                       FontWeight="Bold"/>

                            <TextBlock Text="Capture Hotkey"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="White"/>

                        </StackPanel>

                    </StackPanel>

                    <Button Grid.Column="1"
                            Width="40"
                            Height="40"
                            Margin="0,10,10,10"
                            Content="?"
                            Background="#55203030"
                            BorderBrush="#FF5A7A"
                            Click="CancelButton_Click"/>

                </Grid>

            </Border>

            <!-- CONTENT -->

            <Border Grid.Row="1"
                    Style="{StaticResource GlassPanel}"
                    Margin="0,15,0,15">

                <StackPanel Margin="18">

                    <TextBlock Text="Record Shortcut"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#00D8FF"/>

                    <TextBlock Text="Press Record, then press your desired key combination. Press Enter when finished."
                               Foreground="#A1B2D2"
                               TextWrapping="Wrap"
                               Margin="0,8,0,18"/>

                    <Border Background="#22000000"
                            BorderBrush="#3370AFFF"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="18">

                        <StackPanel>

                            <TextBlock Text="CURRENT HOTKEY"
                                       Foreground="#7BA1D8"
                                       FontWeight="SemiBold"/>

                            <TextBlock Text="{Binding CapturedHotkey}"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,6,0,0"/>

                        </StackPanel>

                    </Border>

                </StackPanel>

            </Border>

            <!-- FOOTER -->

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">

                <Button x:Name="RecordButton"
                        Content="Record"
                        Width="110"
                        Margin="0,0,10,0"
                        Style="{StaticResource GlassButton}"
                        Click="RecordButton_Click"/>

                <Button x:Name="DoneButton"
                        Content="Done"
                        Width="110"
                        Margin="0,0,10,0"
                        IsDefault="True"
                        IsEnabled="False"
                        Click="DoneButton_Click">

                    <Button.Background>

                        <LinearGradientBrush StartPoint="0,0"
                                             EndPoint="1,0">

                            <GradientStop Color="#00D8FF"
                                          Offset="0"/>

                            <GradientStop Color="#FF44CC"
                                          Offset="1"/>

                        </LinearGradientBrush>

                    </Button.Background>

                </Button>

                <Button x:Name="CancelButton"
                        Content="Cancel"
                        Width="110"
                        IsCancel="True"
                        Style="{StaticResource GlassButton}"
                        Click="CancelButton_Click"/>

            </StackPanel>

        </Grid>

    </Border>

</Window>