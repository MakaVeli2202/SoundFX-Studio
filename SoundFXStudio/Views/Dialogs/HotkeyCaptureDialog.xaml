<Window x:Class="SoundFXStudio.Views.Dialogs.HotkeyCaptureDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Capture Hotkey"
        Width="460"
        Height="240"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        Loaded="Window_Loaded"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Border Background="#0E1728" CornerRadius="18" BorderBrush="#2E4568" BorderThickness="1" Padding="18">
        <StackPanel>
            <TextBlock Text="Record Shortcut" FontSize="22" FontWeight="Bold" Foreground="#EAF1FF" />
            <TextBlock Text="Press Record, type your key combination, then confirm with Enter." TextWrapping="Wrap" Opacity="0.78" Margin="0,6,0,16" Foreground="#A4B2C9" />

            <Border Background="#101A2D" CornerRadius="14" Padding="14" Margin="0,0,0,14" BorderBrush="#2E4568" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Current Shortcut" Opacity="0.72" Foreground="#A4B2C9" />
                    <TextBlock Text="{Binding CapturedHotkey}" FontSize="24" FontWeight="Bold" Margin="0,4,0,0" Foreground="#EAF1FF" />
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="RecordButton" Content="Record" Width="96" Margin="0,0,8,0" Click="RecordButton_Click" />
                <Button x:Name="DoneButton" Content="Done" Width="96" Margin="0,0,8,0" Click="DoneButton_Click" IsDefault="True" IsEnabled="False" />
                <Button x:Name="CancelButton" Content="Cancel" Width="96" Click="CancelButton_Click" IsCancel="True" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>