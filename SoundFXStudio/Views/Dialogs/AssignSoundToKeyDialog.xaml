<Window x:Class="SoundFXStudio.Views.Dialogs.AssignSoundToKeyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Assign Sound"
        Width="520"
        Height="620"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#050505"
        Icon="/Assets/SoundFXStudioLogo.png">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#0D0D0D" />
        <SolidColorBrush x:Key="SecondaryPanelBrush" Color="#141414" />
        <SolidColorBrush x:Key="BorderBrushTheme" Color="#2B2B2B" />
        <SolidColorBrush x:Key="TextBrush" Color="#F5F7FB" />
        <SolidColorBrush x:Key="MutedBrush" Color="#A0A7B4" />
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource SecondaryPanelBrush}"
                BorderBrush="#252525"
                BorderThickness="1"
                CornerRadius="16"
                Padding="12"
                Margin="0,0,0,14">
            <Grid MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="42"
                            Height="42"
                            CornerRadius="12"
                            Background="#0A0A0A"
                            BorderBrush="#303030"
                            BorderThickness="1"
                            Padding="4"
                            Margin="0,0,12,0">
                        <Image Source="/Assets/SoundFXStudioLogo.png" Stretch="Uniform" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="SoundFX Studio" FontSize="13" FontWeight="Bold" Foreground="{StaticResource MutedBrush}" />
                        <TextBlock Text="Assign Sound To Key" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="✕"
                        Width="40"
                        Height="30"
                        VerticalAlignment="Top"
                        Background="#2A1118"
                        BorderBrush="#5F2336"
                        Click="CloseButton_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushTheme}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="12"
                Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="Choose a sound for the selected keyboard button." Foreground="{StaticResource MutedBrush}" Margin="0,0,0,10" />
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Height="36"
                         VerticalContentAlignment="Center" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Background="{StaticResource SecondaryPanelBrush}"
                BorderBrush="{StaticResource BorderBrushTheme}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ListBox ItemsSource="{Binding FilteredSounds}"
                         SelectedItem="{Binding SelectedSound, Mode=TwoWay}"
                         Background="#101010"
                         BorderThickness="0"
                         Foreground="{StaticResource TextBrush}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10" Margin="0,0,0,8" Background="#161616" CornerRadius="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Width="52" Height="52" CornerRadius="10" Background="#0C0C0C" ClipToBounds="True">
                                        <Image Source="{Binding ImagePath}" Stretch="Uniform" />
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Category}" Foreground="{StaticResource MutedBrush}" Margin="0,3,0,0" />
                                        <TextBlock Text="{Binding FilePath}" Foreground="#7D8797" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,3,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Grid.Row="1"
                           Text="No sounds match the current search."
                           Foreground="{StaticResource MutedBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"
                           Visibility="{Binding EmptyStateVisibility}" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="Cancel"
                    Width="100"
                    Margin="0,0,10,0"
                    Click="CancelButton_Click"
                    Background="#303030"
                    Foreground="{StaticResource TextBrush}" />
            <Button Content="Assign"
                    Width="110"
                    Click="AssignButton_Click"
                    Background="#36D1FF"
                    Foreground="Black"
                    FontWeight="Bold" />
        </StackPanel>
    </Grid>
</Window>