<Window x:Class="SoundFXStudio.Views.Dialogs.VolumeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Volume"
        Width="460"
        Height="280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#050505"
        WindowStyle="None"
        Icon="/Assets/SoundFXStudioLogo.png">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#0D0D0D" />
        <SolidColorBrush x:Key="SecondaryPanelBrush" Color="#141414" />
        <SolidColorBrush x:Key="BorderBrushTheme" Color="#2B2B2B" />
        <SolidColorBrush x:Key="TextBrush" Color="#F5F7FB" />
        <SolidColorBrush x:Key="MutedBrush" Color="#A0A7B4" />
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource SecondaryPanelBrush}" BorderBrush="#252525" BorderThickness="1" CornerRadius="16" Padding="12" Margin="0,0,0,14">
            <Grid MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="42" Height="42" CornerRadius="12" Background="#0A0A0A" BorderBrush="#303030" BorderThickness="1" Padding="4" Margin="0,0,12,0">
                        <Image Source="/Assets/SoundFXStudioLogo.png" Stretch="Uniform" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="SoundFX Studio" FontSize="13" FontWeight="Bold" Foreground="{StaticResource MutedBrush}" />
                        <TextBlock Text="Key Volume" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
                    </StackPanel>
                </StackPanel>
                <Button Grid.Column="1" Content="✕" Width="40" Height="30" VerticalAlignment="Top" Background="#2A1118" BorderBrush="#5F2336" Click="CloseButton_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource SecondaryPanelBrush}" BorderBrush="{StaticResource BorderBrushTheme}" BorderThickness="1" CornerRadius="14" Padding="16">
            <StackPanel>
                <TextBlock Text="Adjust the playback volume for this key binding." Foreground="{StaticResource MutedBrush}" Margin="0,0,0,12" />
                <Slider Minimum="0" Maximum="100" Value="{Binding VolumePercent, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Text="{Binding VolumePercent, StringFormat={}{0:0}%}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" Margin="0,12,0,0" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Cancel" Width="100" Margin="0,0,10,0" Click="CancelButton_Click" Background="#303030" Foreground="{StaticResource TextBrush}" />
            <Button Content="Save" Width="100" Click="SaveButton_Click" Background="#36D1FF" Foreground="Black" FontWeight="Bold" />
        </StackPanel>
    </Grid>
</Window>