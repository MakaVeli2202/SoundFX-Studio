<Window x:Class="SoundFXStudio.Views.Dialogs.SetupWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Audio Setup Wizard"
        Width="920"
        Height="620"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="/Assets/SoundFXStudioLogo.png">

    <Window.Resources>

        <SolidColorBrush x:Key="TextBrush" Color="#EAF1FF"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#A1B2D2"/>

        <Style x:Key="GlassPanel"
               TargetType="Border">

            <Setter Property="CornerRadius"
                    Value="24"/>

            <Setter Property="Background"
                    Value="#66081428"/>

            <Setter Property="BorderBrush"
                    Value="#5580CFFF"/>

            <Setter Property="BorderThickness"
                    Value="1"/>

        </Style>

        <Style x:Key="CyberButton"
               TargetType="Button">

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="Background"
                    Value="#22112233"/>

            <Setter Property="BorderBrush"
                    Value="#3370AFFF"/>

            <Setter Property="BorderThickness"
                    Value="1"/>

            <Setter Property="Cursor"
                    Value="Hand"/>

            <Setter Property="Height"
                    Value="42"/>

        </Style>

    </Window.Resources>

    <Border Background="#081428"
            CornerRadius="28"
            ClipToBounds="True">

        <Border.BorderBrush>

            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,0">

                <GradientStop Color="#00D8FF"
                              Offset="0"/>

                <GradientStop Color="#FF44CC"
                              Offset="1"/>

            </LinearGradientBrush>

        </Border.BorderBrush>

        <Border.BorderThickness>2</Border.BorderThickness>

        <Grid Margin="18">

            <Grid.RowDefinitions>

                <RowDefinition Height="80"/>

                <RowDefinition Height="Auto"/>

                <RowDefinition Height="*"/>

                <RowDefinition Height="70"/>

            </Grid.RowDefinitions>

            <!-- HEADER -->

            <Border Grid.Row="0"
                    Style="{StaticResource GlassPanel}">

                <Grid MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="*"/>

                        <ColumnDefinition Width="Auto"/>

                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="20,0">

                        <Image Source="/Assets/UI/MainDashboardLogo.png"
                               Height="50"
                               Stretch="Uniform"/>

                        <StackPanel Margin="16,0,0,0">

                            <TextBlock Text="AUDIO SETUP WIZARD"
                                       Foreground="#00D8FF"
                                       FontSize="22"
                                       FontWeight="Bold"/>

                            <TextBlock Text="Configure playback and recording devices"
                                       Foreground="{StaticResource MutedBrush}"/>

                        </StackPanel>

                    </StackPanel>

                    <Button Grid.Column="1"
                            Width="40"
                            Height="40"
                            Margin="0,10,10,10"
                            Content="✕"
                            Background="#55203030"
                            BorderBrush="#FF5A7A"
                            Foreground="White"
                            Click="CloseButton_Click"/>

                </Grid>

            </Border>

            <!-- DESCRIPTION -->

            <TextBlock Grid.Row="1"
                       Margin="5,15,5,15"
                       Foreground="{StaticResource MutedBrush}"
                       FontSize="14"
                       TextWrapping="Wrap"
                       Text="Choose your playback and recording devices and SoundFX Studio will automatically configure your audio routing."/>

            <!-- MAIN CONTENT -->

            <Grid Grid.Row="2">

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="1.3*"/>

                    <ColumnDefinition Width="1*"/>

                </Grid.ColumnDefinitions>

                <!-- DEVICE SETTINGS -->

                <Border Style="{StaticResource GlassPanel}"
                        Margin="0,0,12,0">

                    <StackPanel Margin="16">

                        <TextBlock Text="AUDIO DEVICES"
                                   Foreground="#00D8FF"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,16"/>

                        <TextBlock Text="Speakers (playback output)"
                                   Foreground="{StaticResource MutedBrush}"/>

                        <ComboBox x:Name="OutputCombo"
                                  Margin="0,6,0,12"
                                  Height="36"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"/>

                        <TextBlock x:Name="OutputDefaultText"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="Microphone (voice input)"
                                   Foreground="{StaticResource MutedBrush}"/>

                        <ComboBox x:Name="InputCombo"
                                  Margin="0,6,0,12"
                                  Height="36"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"/>

                        <TextBlock x:Name="InputDefaultText"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"/>

                        <TextBlock x:Name="StatusText"
                                   Margin="0,20,0,0"
                                   Foreground="#00D8FF"
                                   TextWrapping="Wrap"/>

                    </StackPanel>

                </Border>

                <!-- INFO -->

                <Border Grid.Column="1"
                        Style="{StaticResource GlassPanel}">

                    <StackPanel Margin="16">

                        <TextBlock Text="WHAT HAPPENS NEXT"
                                   Foreground="#00D8FF"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,16"/>

                        <TextBlock Text="✓ Configure playback routing"
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="✓ Configure microphone capture"
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="✓ Prepare keyboard sound triggers"
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="✓ Save recommended settings"
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="0,0,0,12"/>

                    </StackPanel>

                </Border>

            </Grid>

            <!-- FOOTER -->

            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">

                <CheckBox x:Name="DontShowAgainCheckBox"
                          Content="Don't show this again"
                          Foreground="{StaticResource TextBrush}"
                          Margin="0,0,20,0"
                          VerticalAlignment="Center"/>

                <Button Content="Open Windows Sound"
                        Width="180"
                        Margin="0,0,10,0"
                        Style="{StaticResource CyberButton}"
                        Click="OpenSound_Click"/>

                <Button Content="Auto Configure"
                        Width="160"
                        Margin="0,0,10,0"
                        Style="{StaticResource CyberButton}"
                        Click="AutoConfigure_Click"/>

                <Button Content="Finish"
                        Width="130"
                        FontWeight="Bold"
                        Foreground="#081428"
                        Click="Finish_Click">

                    <Button.Background>

                        <LinearGradientBrush StartPoint="0,0"
                                             EndPoint="1,0">

                            <GradientStop Color="#00D8FF"/>

                            <GradientStop Color="#FF44CC"/>

                        </LinearGradientBrush>

                    </Button.Background>

                </Button>

            </StackPanel>

        </Grid>

    </Border>

</Window>