<Window x:Class="SoundFXStudio.Views.Dialogs.SoundAssignmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Sound"
        Height="550"
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#121212">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Sound Assignment"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="White"
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">

            <TextBlock Text="Sound Name" Foreground="White"/>
            <TextBox Text="{Binding Name}" Margin="0,5,0,12"/>

            <TextBlock Text="Keyboard Key" Foreground="White"/>
            <ComboBox ItemsSource="{Binding AvailableKeys}"
                      SelectedItem="{Binding SelectedKey}"
                      Margin="0,5,0,12"/>

            <TextBlock Text="Category" Foreground="White"/>
            <ComboBox ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding Category}"
                      Margin="0,5,0,12"/>

            <TextBlock Text="Volume" Foreground="White"/>
            <Slider Minimum="0"
                    Maximum="1"
                    Value="{Binding Volume}"
                    Margin="0,5,0,12"/>

            <CheckBox Content="Favorite"
                      IsChecked="{Binding IsFavorite}"
                      Foreground="White"/>

            <CheckBox Content="Loop"
                      IsChecked="{Binding Loop}"
                      Foreground="White"
                      Margin="0,6,0,0"/>

            <Button Content="Choose Image"
                    Command="{Binding ChooseImageCommand}"
                    Margin="0,15,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <Button Content="Cancel"
                    Width="100"
                    Margin="0,0,10,0"/>

            <Button Content="Save"
                    Width="100"/>
        </StackPanel>

    </Grid>

</Window>