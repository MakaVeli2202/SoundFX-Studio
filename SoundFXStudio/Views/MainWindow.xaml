<Window x:Class="SoundFXStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SoundFXStudio.Controls"
        Title="SoundFX Studio"
        Width="1600"
        Height="920"
        MinWidth="1280"
        MinHeight="760"
        Background="#050505"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#050505" />
        <SolidColorBrush x:Key="PanelBrush" Color="#0D0D0D" />
        <SolidColorBrush x:Key="SecondaryPanelBrush" Color="#141414" />
        <SolidColorBrush x:Key="KeyboardSurfaceBrush" Color="#090909" />
        <SolidColorBrush x:Key="BorderBrushTheme" Color="#252525" />
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#9D9D9D" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#191919" />
            <Setter Property="BorderBrush" Value="#303030" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#131313" />
            <Setter Property="BorderBrush" Value="#303030" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#131313" />
            <Setter Property="BorderBrush" Value="#303030" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#131313" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>

        <Style TargetType="ListView">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#101010" />
            <Setter Property="BorderBrush" Value="#303030" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#101010" />
            <Setter Property="Padding" Value="4" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#111111" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushTheme}" />
            <Setter Property="Padding" Value="16,9" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Border Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushTheme}"
                BorderThickness="1"
                CornerRadius="28">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Background="{StaticResource SecondaryPanelBrush}"
                        CornerRadius="28,28,0,0"
                        BorderBrush="{StaticResource BorderBrushTheme}"
                        BorderThickness="0,0,0,1"
                        Padding="24,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="SoundFX Studio" FontSize="30" FontWeight="Bold" />
                            <TextBlock Text="Keyboard-first soundboard" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="#181818"
                                    BorderBrush="#303030"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="12,8"
                                    Margin="0,0,12,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Language" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource SecondaryTextBrush}" />
                                    <ComboBox Width="150"
                                              SelectedItem="{Binding KeyboardLayout, Mode=TwoWay}"
                                              ItemsSource="{Binding KeyboardLayoutOptions}" />
                                </StackPanel>
                            </Border>

                            <ComboBox Width="140"
                                      Margin="0,0,12,0"
                                      ItemsSource="{Binding ThemeOptions}"
                                      SelectedItem="{Binding SelectedTheme, Mode=TwoWay}" />

                            <Button Content="Save"
                                    Width="100"
                                    Height="40"
                                    Command="{Binding SaveCommand}"
                                    Margin="0,0,10,0" />
                            <Button Content="Refresh"
                                    Width="100"
                                    Height="40"
                                    Command="{Binding RefreshCommand}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <TabControl Grid.Row="1"
                            Margin="20"
                            SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrushTheme}"
                            BorderThickness="1">
                    <TabItem Header="Keyboard">
                        <Border Background="{StaticResource KeyboardSurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrushTheme}"
                                BorderThickness="1"
                                CornerRadius="24"
                                Padding="12"
                                Margin="8">
                            <Viewbox Stretch="Uniform"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <controls:KeyboardControl ItemsSource="{Binding KeyboardKeys}"
                                                          KeyClickedCommand="{Binding KeyClickedCommand}" />
                            </Viewbox>
                        </Border>
                    </TabItem>

                    <TabItem Header="Library">
                        <Grid Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="340" />
                            </Grid.ColumnDefinitions>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBox Width="240"
                                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Search sounds" />
                                    <ComboBox Width="160"
                                              Margin="10,0,0,0"
                                              ItemsSource="{Binding Categories}"
                                              DisplayMemberPath="Name"
                                              SelectedValuePath="Name"
                                              SelectedValue="{Binding SelectedCategoryFilter, Mode=TwoWay}" />
                                    <CheckBox Content="Favorites only"
                                              IsChecked="{Binding FavoritesOnly, Mode=TwoWay}"
                                              VerticalAlignment="Center"
                                              Margin="12,0,0,0" />
                                </StackPanel>

                                <StackPanel Grid.Row="1">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Button Content="Add"
                                                Command="{Binding AddSoundCommand}" />
                                        <Button Content="Add URL"
                                            Command="{Binding AddSoundFromUrlCommand}"
                                            Margin="10,0,0,0" />
                                        <Button Content="Bulk import"
                                                Command="{Binding AddMultipleSoundsCommand}"
                                                Margin="10,0,0,0" />
                                        <Button Content="Bulk delete"
                                                Command="{Binding DeleteMarkedSoundsCommand}"
                                                Margin="10,0,0,0" />
                                        <Button Content="Play"
                                                Command="{Binding PlaySelectedSoundCommand}"
                                                Margin="10,0,0,0" />
                                        <Button Content="Favorite"
                                                Command="{Binding ToggleFavoriteCommand}"
                                                Margin="10,0,0,0" />
                                        <Button Content="Delete"
                                                Command="{Binding DeleteSoundCommand}"
                                                Margin="10,0,0,0" />
                                    </StackPanel>

                                    <ListView ItemsSource="{Binding SoundsView}"
                                              SelectedItem="{Binding SelectedSound}">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Mark" Width="52">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <CheckBox IsChecked="{Binding IsMarkedForDelete, Mode=TwoWay}" HorizontalAlignment="Center" />
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="220" />
                                                <GridViewColumn Header="Category" DisplayMemberBinding="{Binding Category}" Width="140" />
                                                <GridViewColumn Header="Hotkey" DisplayMemberBinding="{Binding Hotkey}" Width="120" />
                                                <GridViewColumn Header="Fav" DisplayMemberBinding="{Binding IsFavorite}" Width="60" />
                                                <GridViewColumn Header="Plays" DisplayMemberBinding="{Binding PlayCount}" Width="80" />
                                                <GridViewColumn Header="Assigned Key" DisplayMemberBinding="{Binding AssignedKeyId}" Width="240" />
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </StackPanel>
                            </Grid>

                            <Border Grid.Column="1"
                                    Margin="12,0,0,0"
                                    Background="#0B1320"
                                    CornerRadius="20"
                                    Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Preview" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" />
                                    <Border Height="160" Background="#111A2D" CornerRadius="16" Margin="0,0,0,12">
                                        <Grid>
                                            <Image Source="{Binding SelectedSound.ImagePath}" Stretch="UniformToFill" Opacity="0.45" />
                                            <TextBlock Text="{Binding SelectedSound.Name}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                    <TextBlock Text="{Binding SelectedSound.Category}" Opacity="0.78" />
                                    <TextBlock Text="{Binding SelectedSound.Hotkey}" Opacity="0.78" />
                                    <TextBlock Text="{Binding SelectedSound.PlayCount, StringFormat=Plays: {0}}" Opacity="0.78" />
                                    <TextBlock Text="{Binding StatusText}" Margin="0,12,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Settings">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8">
                                <TextBlock Text="General" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />
                                <CheckBox Content="Enable global hotkeys" IsChecked="{Binding Settings.EnableGlobalHotkeys, Mode=TwoWay}" Margin="0,0,0,8" />
                                <CheckBox Content="Start minimized" IsChecked="{Binding Settings.StartMinimized, Mode=TwoWay}" Margin="0,0,0,8" />
                                <CheckBox Content="Allow multiple instances" IsChecked="{Binding Settings.AllowMultipleInstances, Mode=TwoWay}" Margin="0,0,0,8" />

                                <TextBlock Text="Appearance" FontSize="18" FontWeight="Bold" Margin="0,12,0,8" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="Theme" Width="160" VerticalAlignment="Center" />
                                    <ComboBox Width="180"
                                              ItemsSource="{Binding ThemeOptions}"
                                              SelectedItem="{Binding SelectedTheme, Mode=TwoWay}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="Keyboard layout" Width="160" VerticalAlignment="Center" />
                                    <ComboBox Width="180"
                                              ItemsSource="{Binding KeyboardLayoutOptions}"
                                              SelectedItem="{Binding KeyboardLayout, Mode=TwoWay}" />
                                </StackPanel>

                                <TextBlock Text="Audio Devices" FontSize="18" FontWeight="Bold" Margin="0,12,0,8" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="Output" Width="160" VerticalAlignment="Center" />
                                    <ComboBox Width="360"
                                              ItemsSource="{Binding OutputDevices}"
                                              DisplayMemberPath="Name"
                                              SelectedValuePath="Id"
                                              SelectedValue="{Binding Settings.OutputDeviceId, Mode=TwoWay}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="Input" Width="160" VerticalAlignment="Center" />
                                    <ComboBox Width="360"
                                              ItemsSource="{Binding InputDevices}"
                                              DisplayMemberPath="Name"
                                              SelectedValuePath="Id"
                                              SelectedValue="{Binding Settings.InputDeviceId, Mode=TwoWay}" />
                                </StackPanel>
                                <Button Content="Auto-configure audio"
                                    Width="180"
                                    Margin="160,4,0,0"
                                    HorizontalAlignment="Left"
                                    Command="{Binding AutoConfigureAudioCommand}" />

                                <TextBlock Text="Hotkeys" FontSize="18" FontWeight="Bold" Margin="0,12,0,8" />
                                <TextBlock Text="Global hotkeys are registered per profile assignment. Key bindings can be edited from the keyboard context menu." TextWrapping="Wrap" Opacity="0.78" Margin="0,0,0,8" />

                                <TextBlock Text="Profiles" FontSize="18" FontWeight="Bold" Margin="0,12,0,8" />
                                <TextBlock Text="Profiles switch assignments, categories, and keyboard state instantly through the existing profile list." TextWrapping="Wrap" Opacity="0.78" Margin="0,0,0,8" />

                                <TextBlock Text="Advanced" FontSize="18" FontWeight="Bold" Margin="0,12,0,8" />
                                <TextBlock Text="Storage is file-based under AppData. Future effects, voice tools, and cloud sync can hook into the same model and config services." TextWrapping="Wrap" Opacity="0.78" Margin="0,0,0,8" />

                                <TextBlock Text="Storage" FontSize="18" FontWeight="Bold" Margin="0,12,0,8" />
                                <TextBlock Text="Config, sounds, and images are stored under the app data folder managed by ConfigService." TextWrapping="Wrap" Opacity="0.78" />
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Profiles">
                        <Grid Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="360" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBox Width="220"
                                             Text="{Binding ProfileSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Search profiles" />
                                    <Button Content="New"
                                            Command="{Binding CreateProfileCommand}"
                                            Margin="10,0,0,0" />
                                </StackPanel>

                                <ListBox ItemsSource="{Binding ProfilesView}"
                                         SelectedItem="{Binding SelectedProfile}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#355275"
                                                    BorderThickness="1"
                                                    CornerRadius="12"
                                                    Padding="10"
                                                    Margin="0,0,0,8">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" />
                                                    <TextBlock Text="{Binding Description}" Opacity="0.72" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Margin="12,0,0,0"
                                    Background="#0B1320"
                                    CornerRadius="20"
                                    Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Selected profile" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />
                                    <TextBlock Text="{Binding SelectedProfile.Name}" FontSize="16" />
                                    <TextBlock Text="{Binding StatusText}" Opacity="0.8" Margin="0,6,0,12" />
                                    <TextBlock Text="Assignments are stored on the profile and drive the keyboard layout state." TextWrapping="Wrap" Opacity="0.78" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Statistics">
                        <Grid Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Most Played" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" />
                                <ListBox ItemsSource="{Binding MostPlayedSounds}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" />
                                                <TextBlock Text="{Binding PlayCount, StringFormat=Plays: {0}}" Opacity="0.72" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Text="Recent" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" />
                                <ListBox ItemsSource="{Binding RecentSounds}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" />
                                                <TextBlock Text="{Binding LastPlayedUtc}" Opacity="0.72" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="12,0,0,0">
                                <TextBlock Text="Favorites" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" />
                                <ListBox ItemsSource="{Binding FavoriteSounds}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" />
                                                <TextBlock Text="{Binding Category}" Opacity="0.72" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>
    </Grid>
</Window>