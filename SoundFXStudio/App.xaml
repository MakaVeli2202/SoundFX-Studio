<Application x:Class="SoundFXStudio.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:media="clr-namespace:System.Windows.Media.Imaging;assembly=PresentationCore"
             xmlns:converters="clr-namespace:SoundFXStudio.Converters"
             Startup="App_Startup"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <converters:EmptyToVisibilityConverter x:Key="EmptyToVisibilityConverter" />
        <converters:NonEmptyToVisibilityConverter x:Key="NonEmptyToVisibilityConverter" />
        <media:BitmapImage x:Key="SoundFXLogo" UriSource="pack://application:,,,/Assets/SoundFXStudioLogo.png" />

        <SolidColorBrush x:Key="BrandCyan" Color="#5AD8FF" />
        <SolidColorBrush x:Key="BrandMagenta" Color="#FF6B8E" />
        <SolidColorBrush x:Key="BrandPurple" Color="#6C8CFF" />
        <SolidColorBrush x:Key="UiWindowBrush" Color="#0A1220" />
        <SolidColorBrush x:Key="UiPanelBrush" Color="#111B2E" />
        <SolidColorBrush x:Key="UiPanelAltBrush" Color="#0D1626" />
        <SolidColorBrush x:Key="UiBorderBrush" Color="#2F466A" />
        <SolidColorBrush x:Key="UiTextBrush" Color="#EAF1FF" />
        <SolidColorBrush x:Key="UiMutedTextBrush" Color="#A2B0C9" />

        <Style x:Key="WindowChromeBar" TargetType="Border">
            <Setter Property="Background" Value="#B3131313" />
            <Setter Property="BorderBrush" Value="#70343434" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>

        <Style x:Key="WindowChromeButton" TargetType="Button">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ChromeRoot"
                                CornerRadius="0"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChromeRoot" Property="Background" Value="#55383838" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ChromeRoot" Property="Background" Value="#66303030" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowChromeCloseButton" TargetType="Button" BasedOn="{StaticResource WindowChromeButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ChromeRoot"
                                CornerRadius="0"
                                Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChromeRoot" Property="Background" Value="#66A11919" />
                                <Setter Property="Foreground" Value="#FFFF4D4D" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ChromeRoot" Property="Background" Value="#88A11919" />
                                <Setter Property="Foreground" Value="#FFFF8A8A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource UiTextBrush}" />
            <Setter Property="Background" Value="{StaticResource UiPanelAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource UiBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="7,4" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="PART_ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <Grid>
                                    <TextBlock Text="&#x25BC;"
                                               FontSize="10"
                                               Foreground="White"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               Margin="0,0,8,0"
                                               IsHitTestVisible="False" />
                                </Grid>
                            </ToggleButton>
                            <ContentPresenter Name="PART_ContentPresenter"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              Margin="0,0,24,0" />
                            <Popup Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="{StaticResource UiPanelAltBrush}"
                                    BorderBrush="{StaticResource UiBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Margin="0,2,0,0">
                                    <ScrollViewer Margin="0,4,0,4">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource UiTextBrush}" />
            <Setter Property="Background" Value="{StaticResource UiPanelAltBrush}" />
            <Setter Property="Padding" Value="7,4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#5AD8FF" />
                    <Setter Property="Foreground" Value="#05101C" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF6B8E" />
                    <Setter Property="Foreground" Value="#101825" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource UiPanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource UiTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource UiBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1B2A43" />
                    <Setter Property="BorderBrush" Value="#6E95C9" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#3D5F8A" />
                    <Setter Property="BorderBrush" Value="#8FCFFF" />
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="0.98" ScaleY="0.98" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource UiTextBrush}" />
            <Setter Property="Background" Value="{StaticResource UiPanelAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource UiBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="{StaticResource UiTextBrush}" />
            <Setter Property="Background" Value="{StaticResource UiPanelAltBrush}" />
            <Setter Property="Padding" Value="2" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#5AD8FF" />
                    <Setter Property="Foreground" Value="#05101C" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource UiTextBrush}" />
            <Setter Property="Background" Value="{StaticResource UiPanelAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource UiBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF6B8E" Offset="0" />
                                <GradientStop Color="#6C8CFF" Offset="0.5" />
                                <GradientStop Color="#5AD8FF" Offset="1" />
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="BorderBrush" Value="#5AD8FF" />
                    <Setter Property="Foreground" Value="#05101C" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#171717" />
                    <Setter Property="BorderBrush" Value="#22D3FF" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
</Application>
