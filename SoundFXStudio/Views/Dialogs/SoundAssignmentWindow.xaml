<Window x:Class="SoundFXStudio.Views.Dialogs.SoundAssignmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Sound"
        Height="680"
        Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#050505">

    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#0D0D0D" />
        <SolidColorBrush x:Key="SecondaryPanelBrush" Color="#141414" />
        <SolidColorBrush x:Key="BorderBrushTheme" Color="#2B2B2B" />
        <SolidColorBrush x:Key="TextBrush" Color="#F5F7FB" />
        <SolidColorBrush x:Key="MutedBrush" Color="#A0A7B4" />
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,16">
            <TextBlock Text="Add Sound to Keyboard" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
            <TextBlock Text="Upload an audio file and assign it to a keyboard button" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0" />
        </StackPanel>

        <Border Grid.Row="1"
                Background="{StaticResource SecondaryPanelBrush}"
                BorderBrush="{StaticResource BorderBrushTheme}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="18">
            <ScrollViewer>
                <StackPanel>
                    <!-- File Selection -->
                    <Border Background="{StaticResource PanelBrush}" CornerRadius="12" Padding="14" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="📁 Sound File" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />
                            <TextBlock Text="Pick an audio file (MP3, WAV, OGG, FLAC)" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,10" />
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                
                                <TextBox x:Name="FilePathBox" 
                                         IsReadOnly="True" 
                                         Text="{Binding FilePath, Mode=OneWay}"
                                         Height="36" 
                                         Padding="12,8"
                                         Background="{StaticResource PanelBrush}"
                                         BorderBrush="{StaticResource BorderBrushTheme}"
                                         BorderThickness="1"
                                         Foreground="{StaticResource TextBrush}"
                                         Margin="0,0,10,0"/>
                                
                                <Button x:Name="BrowseButton" 
                                        Content="Browse" 
                                        Width="100" 
                                        Height="36"
                                        Grid.Column="1"
                                        Click="BrowseButton_Click"
                                        Background="#36D1FF"
                                        Foreground="Black"
                                        FontWeight="Bold" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Display Name -->
                    <StackPanel Margin="0,0,0,14">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Sound Name" FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
                            <TextBlock Text="(label on keyboard button)" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="8,2,0,0" />
                        </StackPanel>
                        <TextBox x:Name="NameBox"
                                 Text="{Binding Name}"
                                 Height="40"
                                 Padding="12,10"
                                 Background="{StaticResource PanelBrush}"
                                 BorderBrush="{StaticResource BorderBrushTheme}"
                                 BorderThickness="1"
                                 Foreground="{StaticResource TextBrush}" />
                    </StackPanel>

                    <!-- Keyboard Button Selection -->
                    <StackPanel Margin="0,0,0,14">
                        <TextBlock Text="⌨️ Keyboard Button" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6" />
                        <ComboBox ItemsSource="{Binding AvailableKeys}"
                                  SelectedItem="{Binding SelectedKey}"
                                  Height="40"
                                  Padding="12,8"
                                  Background="{StaticResource PanelBrush}"
                                  BorderBrush="{StaticResource BorderBrushTheme}"
                                  BorderThickness="1"
                                  Foreground="{StaticResource TextBrush}" />
                    </StackPanel>

                    <!-- Category -->
                    <StackPanel Margin="0,0,0,14">
                        <TextBlock Text="📂 Sound Group" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6" />
                        <ComboBox ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding Category}"
                                  Height="40"
                                  Padding="12,8"
                                  Background="{StaticResource PanelBrush}"
                                  BorderBrush="{StaticResource BorderBrushTheme}"
                                  BorderThickness="1"
                                  Foreground="{StaticResource TextBrush}" />
                    </StackPanel>

                    <!-- Volume -->
                    <StackPanel Margin="0,0,0,14">
                        <TextBlock Text="🔊 Volume" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="50" />
                            </Grid.ColumnDefinitions>
                            <Slider Minimum="0"
                                    Maximum="100"
                                    Value="{Binding VolumePercent}"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center"
                                    Foreground="#36D1FF" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding VolumePercent, StringFormat='0%'}"
                                       Foreground="{StaticResource MutedBrush}"
                                       VerticalAlignment="Center"
                                       TextAlignment="Right" />
                        </Grid>
                    </StackPanel>

                    <!-- Options -->
                    <StackPanel Margin="0,0,0,14">
                        <TextBlock Text="⚙️ Options" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,10" />
                        <CheckBox Content="Mark as favorite (⭐ icon)"
                                  IsChecked="{Binding IsFavorite}"
                                  Foreground="{StaticResource TextBrush}"
                                  Margin="0,0,0,8" />
                        <CheckBox Content="Loop sound continuously"
                                  IsChecked="{Binding Loop}"
                                  Foreground="{StaticResource TextBrush}" />
                    </StackPanel>

                    <!-- Image Selection -->
                    <Border Background="{StaticResource PanelBrush}" CornerRadius="12" Padding="14">
                        <StackPanel>
                            <TextBlock Text="🖼️ Custom Image (Optional)" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,10" />
                            
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                
                                <TextBox x:Name="ImagePathBox" 
                                         IsReadOnly="True" 
                                         Text="{Binding ImagePath, Mode=OneWay}"
                                         Height="36"
                                         Padding="12,8"
                                         Background="{StaticResource SecondaryPanelBrush}"
                                         BorderBrush="{StaticResource BorderBrushTheme}"
                                         BorderThickness="1"
                                         Foreground="{StaticResource TextBrush}" />
                                
                                <Button x:Name="ImageBrowseButton" 
                                        Content="Choose" 
                                        Width="90" 
                                        Height="36"
                                        Grid.Column="1"
                                        Margin="10,0,0,0"
                                        Click="ImageBrowseButton_Click"
                                        Background="#36D1FF"
                                        Foreground="Black"
                                        FontWeight="Bold" />
                            </Grid>
                            
                            <!-- Image Preview -->
                            <Border x:Name="ImagePreviewBorder"
                                    Background="{StaticResource PanelBrush}"
                                    CornerRadius="8"
                                    Height="120"
                                    BorderBrush="{StaticResource BorderBrushTheme}"
                                    BorderThickness="1">
                                <Image x:Name="ImagePreview"
                                       Source="{Binding ImagePath, Mode=OneWay}"
                                       Stretch="UniformToFill" />
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Cancel"
                    Width="100"
                    Margin="0,0,10,0"
                    Click="CancelButton_Click"
                    Background="#303030"
                    Foreground="{StaticResource TextBrush}" />
            <Button Content="Save"
                    Width="100"
                    Click="SaveButton_Click"
                    Background="#36D1FF"
                    Foreground="Black"
                    FontWeight="Bold" />
        </StackPanel>
    </Grid>
</Window>