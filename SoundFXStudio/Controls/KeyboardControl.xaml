<UserControl x:Class="SoundFXStudio.Controls.KeyboardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:SoundFXStudio.Controls"
             xmlns:converters="clr-namespace:SoundFXStudio.Converters"
             Background="Transparent"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">

    <UserControl.Resources>
        <converters:KeyboardKeySizeConverter x:Key="KeySizeConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style TargetType="Button">
            <Setter Property="Background" Value="#121A27" />
            <Setter Property="Foreground" Value="#F5F7FB" />
            <Setter Property="BorderBrush" Value="#2F465D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="12"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <Grid ClipToBounds="True">
                                <Border x:Name="BaseLayer" Background="#121A27" CornerRadius="12" />
                                <Border x:Name="HoverGlow" Background="#00000000" CornerRadius="12" Opacity="0" />
                                <Border x:Name="PlayingGlow" Background="#00000000" CornerRadius="12" Opacity="0" />
                                <Border x:Name="SelectionRing"
                                        Margin="1"
                                        CornerRadius="11"
                                        BorderBrush="#00000000"
                                        BorderThickness="0"
                                        Opacity="0" />
                                <ContentPresenter HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Stretch"
                                                  Margin="0"
                                                  RecognizesAccessKey="True" />
                                <Border x:Name="PlayingBar"
                                        Height="3"
                                        Margin="10,0,10,8"
                                        CornerRadius="1.5"
                                        VerticalAlignment="Bottom"
                                        Background="#36D1FF"
                                        Opacity="0" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#67D1FF" />
                                <Setter TargetName="BaseLayer" Property="Background" Value="#172232" />
                                <Setter TargetName="HoverGlow" Property="Opacity" Value="1" />
                                <Setter TargetName="HoverGlow" Property="Background" Value="#1667D1FF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.975" ScaleY="0.975" />
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#8BC4FF" />
                                <Setter TargetName="BaseLayer" Property="Background" Value="#203447" />
                                <Setter TargetName="HoverGlow" Property="Opacity" Value="1" />
                                <Setter TargetName="HoverGlow" Property="Background" Value="#2546F1FF" />
                                <Setter TargetName="PlayingBar" Property="Opacity" Value="0.4" />
                            </Trigger>
                            <DataTrigger Binding="{Binding HasAssignment}" Value="False">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#2F465D" />
                                <Setter TargetName="BaseLayer" Property="Background" Value="#111923" />
                                <Setter TargetName="PlayingGlow" Property="Opacity" Value="0" />
                                <Setter TargetName="PlayingBar" Property="Opacity" Value="0" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding HasAssignment}" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#4CD7FF" />
                                <Setter TargetName="BaseLayer" Property="Background" Value="#172434" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding State}" Value="Pressed">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#6EE7FF" />
                                <Setter TargetName="BaseLayer" Property="Background" Value="#20384F" />
                                <Setter TargetName="PlayingBar" Property="Opacity" Value="0.6" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding State}" Value="Playing">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#36D1FF" />
                                <Setter TargetName="BaseLayer" Property="Background" Value="#183144" />
                                <Setter TargetName="PlayingGlow" Property="Opacity" Value="1" />
                                <Setter TargetName="PlayingGlow" Property="Background" Value="#2346F1FF" />
                                <Setter TargetName="PlayingBar" Property="Opacity" Value="1" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="SelectionRing" Property="BorderThickness" Value="2" />
                                <Setter TargetName="SelectionRing" Property="BorderBrush" Value="#FF4D8D" />
                                <Setter TargetName="SelectionRing" Property="Opacity" Value="1" />
                            </DataTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="#09111B"
            CornerRadius="22"
            BorderBrush="#223A56"
            BorderThickness="1"
            Padding="8">
        <ItemsControl ItemsSource="{Binding ItemsSource, RelativeSource={RelativeSource AncestorType=UserControl}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <controls:KeyboardLayoutPanel />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Command="{Binding DataContext.KeyClickedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            Width="{Binding WidthUnits, Converter={StaticResource KeySizeConverter}, ConverterParameter=Width}"
                            Height="{Binding HeightUnits, Converter={StaticResource KeySizeConverter}, ConverterParameter=Height}">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="➕ Assign Sound"
                                          Command="{Binding DataContext.AssignSelectedSoundToKeyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          CommandParameter="{Binding}" />
                                <MenuItem Header="❌ Remove Sound"
                                          Command="{Binding DataContext.RemoveSoundFromKeyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          CommandParameter="{Binding}" />
                                <MenuItem Header="🖼️ Set Image"
                                          Command="{Binding DataContext.ChooseKeyImageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          CommandParameter="{Binding}" />
                                <MenuItem Header="❌ Remove Image"
                                          Command="{Binding DataContext.RemoveKeyImageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          CommandParameter="{Binding}" />
                                <Separator />
                                <MenuItem Header="📝 Rename Binding"
                                          Command="{Binding DataContext.RenameBindingCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          CommandParameter="{Binding}" />
                                <Separator />
                                <MenuItem Header="🔊 Volume"
                                          Command="{Binding DataContext.ChangeKeyVolumeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          CommandParameter="{Binding}" />
                                <MenuItem Header="🔁 Toggle Loop"
                                          Command="{Binding DataContext.ToggleKeyLoopCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          CommandParameter="{Binding}" />
                                <MenuItem Header="⏹️ Stop Playback"
                                          Command="{Binding DataContext.StopKeyPlaybackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          CommandParameter="{Binding}" />
                                <Separator />
                                <MenuItem Header="📋 Duplicate Binding"
                                          Command="{Binding DataContext.DuplicateBindingCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          CommandParameter="{Binding}" />
                            </ContextMenu>
                        </Button.ContextMenu>

                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding State}" Value="Pressed">
                                        <Setter Property="Background" Value="#20384F" />
                                        <Setter Property="BorderBrush" Value="#6EE7FF" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding State}" Value="Playing">
                                        <Setter Property="Background" Value="#183144" />
                                        <Setter Property="BorderBrush" Value="#36D1FF" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="BorderBrush" Value="#FF4D8D" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding HasAssignment}" Value="True">
                                        <Setter Property="Background" Value="#172434" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Margin="5,6,0,6"
                                    CornerRadius="2"
                                    Background="{Binding CategoryAccentColor}"
                                    Visibility="{Binding HasAssignment, Converter={StaticResource BoolToVisibilityConverter}}" />

                            <Grid Grid.Column="1" Margin="8,7,8,7">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="{Binding DisplayLabel}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap" />

                                <Grid Grid.Row="1"
                                      Margin="0,6,0,4"
                                      Visibility="{Binding HasAssignment, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Border CornerRadius="8"
                                            Background="#14000000" />
                                    <Image Source="{Binding ImagePath}"
                                           Stretch="UniformToFill"
                                           Opacity="0.82"
                                           ClipToBounds="True" />
                                    <Border CornerRadius="8">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#10000000" Offset="0" />
                                                <GradientStop Color="#A8000000" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                </Grid>

                                <StackPanel Grid.Row="2"
                                            Visibility="{Binding HasAssignment, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="{Binding AssignedSoundName}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis"
                                               Opacity="0.96" />
                                    <TextBlock Text="{Binding AssignmentName}"
                                               FontSize="8"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis"
                                               Opacity="0.72" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Border>
</UserControl>