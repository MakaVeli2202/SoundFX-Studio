<Window x:Class="SoundFXStudio.Views.Dialogs.VolumeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Volume"
        Width="460"
        Height="280"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>

        <SolidColorBrush x:Key="TextBrush"
                         Color="#EAF1FF"/>

        <SolidColorBrush x:Key="MutedBrush"
                         Color="#A1B2D2"/>

        <Style x:Key="GlassPanel"
               TargetType="Border">

            <Setter Property="CornerRadius"
                    Value="24"/>

            <Setter Property="Background"
                    Value="#66081428"/>

            <Setter Property="BorderBrush"
                    Value="#5580CFFF"/>

            <Setter Property="BorderThickness"
                    Value="1"/>

        </Style>

        <Style x:Key="CyberButton"
               TargetType="Button">

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="Background"
                    Value="#22112233"/>

            <Setter Property="BorderBrush"
                    Value="#3370AFFF"/>

            <Setter Property="BorderThickness"
                    Value="1"/>

            <Setter Property="Cursor"
                    Value="Hand"/>

            <Setter Property="Height"
                    Value="40"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="ButtonBorder"
                                CornerRadius="14"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">

                                <Setter TargetName="ButtonBorder"
                                        Property="BorderBrush"
                                        Value="#00D8FF"/>

                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#2200D8FF"/>

                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">

                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#33FF44CC"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

    </Window.Resources>

    <Border Background="#081428"
            CornerRadius="28"
            ClipToBounds="True">

        <Border.BorderBrush>

            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,0">

                <GradientStop Color="#00D8FF"
                              Offset="0"/>

                <GradientStop Color="#FF44CC"
                              Offset="1"/>

            </LinearGradientBrush>

        </Border.BorderBrush>

        <Border.BorderThickness>2</Border.BorderThickness>

        <Grid Margin="18">

            <Grid.RowDefinitions>

                <RowDefinition Height="80"/>

                <RowDefinition Height="*"/>

                <RowDefinition Height="70"/>

            </Grid.RowDefinitions>

            <!-- HEADER -->

            <Border Grid.Row="0"
                    Style="{StaticResource GlassPanel}">

                <Grid MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="*"/>

                        <ColumnDefinition Width="Auto"/>

                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="16,0">

                        <Image Source="/Assets/UI/MainDashboardLogo.png"
                               Height="50"
                               Stretch="Uniform"/>

                        <StackPanel Margin="14,0,0,0">

                            <TextBlock Text="SOUNDFX STUDIO"
                                       Foreground="#00D8FF"
                                       FontWeight="Bold"/>

                            <TextBlock Text="KEY VOLUME"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextBrush}"/>

                        </StackPanel>

                    </StackPanel>

                    <Button Grid.Column="1"
                            Width="40"
                            Height="40"
                            Margin="0,10,10,10"
                            Content="&#x2715;"
                            Background="#55203030"
                            BorderBrush="#FF5A7A"
                            Foreground="White"
                            Click="CloseButton_Click"/>

                </Grid>

            </Border>

            <!-- CONTENT -->

            <Border Grid.Row="1"
                    Style="{StaticResource GlassPanel}"
                    Margin="0,14,0,14">

                <StackPanel Margin="18">

                    <TextBlock Text="Adjust the playback volume for this keyboard binding."
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,0,0,18"/>

                    <Slider Minimum="0"
                            Maximum="100"
                            Value="{Binding VolumePercent, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="{Binding VolumePercent, StringFormat={}{0:0}%}"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="#00D8FF"
                               HorizontalAlignment="Center"
                               Margin="0,18,0,0"/>

                </StackPanel>

            </Border>

            <!-- FOOTER -->

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">

                <Button Content="Cancel"
                        Width="100"
                        Margin="0,0,10,0"
                        Style="{StaticResource CyberButton}"
                        Click="CancelButton_Click"/>

                <Button Content="Save"
                        Width="110"
                        FontWeight="Bold"
                        Foreground="#081428"
                        Click="SaveButton_Click">

                    <Button.Background>

                        <LinearGradientBrush StartPoint="0,0"
                                             EndPoint="1,0">

                            <GradientStop Color="#00D8FF"/>

                            <GradientStop Color="#FF44CC"/>

                        </LinearGradientBrush>

                    </Button.Background>

                </Button>

            </StackPanel>

        </Grid>

    </Border>

</Window>