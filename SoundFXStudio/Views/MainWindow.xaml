<Window x:Class="SoundFXStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SoundFXStudio.Controls"
        xmlns:converters="clr-namespace:SoundFXStudio.Converters"
        Title="SoundFX Studio"
        Icon="/Assets/SoundFXStudioLogo.png"
        Width="1366"
        Height="900"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>

        <SolidColorBrush x:Key="WindowBrush"
                         Color="#050A15"/>

        <SolidColorBrush x:Key="PanelBrush"
                         Color="#0A1222"/>

        <SolidColorBrush x:Key="PanelBrushAlt"
                         Color="#0F1830"/>

        <SolidColorBrush x:Key="TextBrush"
                         Color="#EAF1FF"/>

        <SolidColorBrush x:Key="SecondaryTextBrush"
                         Color="#A1B2D2"/>

        <Style x:Key="SidebarButton" TargetType="Button">

            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="65"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Background" Value="#22112233"/>
            <Setter Property="BorderBrush" Value="#3370AFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>


            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="Border"
                        CornerRadius="14"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">

        <Grid PreviewMouseLeftButtonDown="WindowShell_PreviewMouseLeftButtonDown">

                                <Rectangle Fill="#08FFFFFF"
                                   RadiusX="14"
                                   RadiusY="14"/>

                                <ContentPresenter HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  Margin="22,0,0,0"/>

                            </Grid>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                             Value="True">

                                <Setter TargetName="Border"
                                Property="BorderBrush"
                                Value="#00D8FF"/>

                                <Setter TargetName="Border"
                                Property="Background"
                                Value="#331A2948"/>

                            </Trigger>

                            <Trigger Property="IsPressed"
                             Value="True">

                                <Setter TargetName="Border"
                                Property="Background"
                                Value="#552A4580"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

        <Style x:Key="NeonButton"
       TargetType="Button">

            <Setter Property="Foreground"
            Value="White"/>

            <Setter Property="FontWeight"
            Value="Bold"/>

            <Setter Property="FontSize"
            Value="18"/>

            <Setter Property="Height"
            Value="60"/>

            <Setter Property="Cursor"
            Value="Hand"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border CornerRadius="16">

                            <Border.Background>

                                <LinearGradientBrush StartPoint="0,0"
                                             EndPoint="1,0">

                                    <GradientStop Color="#00BFFF"
                                          Offset="0"/>

                                    <GradientStop Color="#AA45FF"
                                          Offset="1"/>

                                </LinearGradientBrush>

                            </Border.Background>

                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>

                        </Border>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

        <Style x:Key="GlassPanel" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Background" Value="#66081428"/>
            <Setter Property="BorderBrush" Value="#5580CFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="GlassComboBox" TargetType="ComboBox">

            <Setter Property="Foreground" Value="White"/>

            <Setter Property="FontSize" Value="14"/>

            <Setter Property="Background" Value="#44111A2E"/>

            <Setter Property="BorderBrush" Value="#5580CFFF"/>

            <Setter Property="BorderThickness" Value="1"/>

            <Setter Property="Padding" Value="10,4"/>

        </Style>

        <Style x:Key="WindowControlButtonStyle" TargetType="Button">

            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#22112233"/>
            <Setter Property="BorderBrush" Value="#3370AFFF"/>
            <Setter Property="BorderThickness" Value="1"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="Border"
                        CornerRadius="10"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">

                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">

                                <Setter TargetName="Border"
                                        Property="Background"
                                        Value="#1100D8FF"/>

                                <Setter TargetName="Border"
                                        Property="BorderBrush"
                                        Value="#00D8FF"/>

                                <Setter TargetName="Border"
                                        Property="BorderThickness"
                                        Value="1"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

        <Style x:Key="HeroOverlayButton"
       TargetType="Button">

            <Setter Property="Background"
            Value="Transparent"/>

            <Setter Property="BorderThickness"
            Value="0"/>

            <Setter Property="Cursor"
            Value="Hand"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="HoverBorder"
                        CornerRadius="10"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0">

                            <ContentPresenter/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                             Value="True">

                                <Setter TargetName="HoverBorder"
                                Property="Background"
                                Value="#1100D8FF"/>

                                <Setter TargetName="HoverBorder"
                                Property="BorderBrush"
                                Value="#33AAFFFF"/>

                                <Setter TargetName="HoverBorder"
                                Property="BorderThickness"
                                Value="1"/>

                            </Trigger>

                            <Trigger Property="IsPressed"
                             Value="True">

                                <Setter TargetName="HoverBorder"
                                Property="Background"
                                Value="#22FF44CC"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

        <Style x:Key="WindowControlButton"
       TargetType="Button">

            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Foreground" Value="#EAF1FF"/>
            <Setter Property="Background" Value="#15000000"/>
            <Setter Property="BorderBrush" Value="#336AAEFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="ChromeBorder"
                        CornerRadius="12"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">

                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                             Value="True">

                                <Setter TargetName="ChromeBorder"
                                Property="BorderBrush"
                                Value="#00D8FF"/>

                                <Setter TargetName="ChromeBorder"
                                Property="Background"
                                Value="#2200D8FF"/>

                            </Trigger>

                            <Trigger Property="IsPressed"
                             Value="True">

                                <Setter TargetName="ChromeBorder"
                                Property="Background"
                                Value="#4400D8FF"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

        <Style x:Key="CloseWindowButton"
       BasedOn="{StaticResource WindowControlButton}"
       TargetType="Button">

            <Setter Property="Background"
            Value="#331E0E12"/>

            <Setter Property="BorderBrush"
            Value="#AAFF4D6D"/>

        </Style>

    </Window.Resources>

    <Border Margin="8,0,8,8"
        CornerRadius="16"
        Background="#070E18">

        <Border.Effect>
            <DropShadowEffect BlurRadius="50"
                          ShadowDepth="0"
                          Color="#000000"
                          Opacity="0.6"/>
        </Border.Effect>

        <Border.BorderBrush>

            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,0">

                <GradientStop Color="#00D8FF"
                              Offset="0"/>

                <GradientStop Color="#FF44CC"
                              Offset="1"/>

            </LinearGradientBrush>

        </Border.BorderBrush>

        <Border.BorderThickness>2</Border.BorderThickness>

        <Grid>

            <!-- Dashboard Skin -->
                 <Image Source="/Assets/UI/MainWindowBackground.png"
                     Stretch="Fill"
                     Margin="0,44,0,0"/>

            <!-- Dashboard Logo -->


            <Image Source="/Assets/UI/MainDashboardLogo.png"
                   Width="250"
                   Height="110"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                    Margin="35,70,0,0">
            </Image>

            <!-- Dashboard Hero Section -->
            <Border Width="930"
                    Height="520"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="300,170,0,0">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource GlassPanel}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentPage}" Value="Home">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Image Source="/Assets/UI/HeroSection.png"
                           Stretch="Uniform"
                           Margin="20"/>

                    <Button Style="{StaticResource HeroOverlayButton}"
                            Width="275"
                            Height="54"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Margin="52,-15,0,0"
                            AutomationProperties.Name="Open Keyboard"
                            AutomationProperties.AutomationId="OpenKeyboardButton"
                            Click="OpenKeyboardWindowButton_Click"/>
                </Grid>
            </Border>

            <!-- Effects Page -->
            <Border Width="930"
                    Height="470"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="300,220,0,0">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource GlassPanel}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentPage}" Value="Effects">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <TextBlock Text="EFFECTS"
                               Foreground="#00D8FF"
                               FontSize="24"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,-40,0,0"/>
                    <TextBlock Text="Coming Soon"
                               Foreground="#A1B2D2"
                               FontSize="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,20,0,0"/>
                </Grid>
            </Border>

            <!-- Sound Library Page -->
            <Border Width="930"
                    Height="470"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="300,220,0,0">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource GlassPanel}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentPage}" Value="SoundLibrary">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="SOUND LIBRARY"
                               Foreground="#00D8FF"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,0,0,16"/>

                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,12,0"/>

                        <Button Grid.Column="1"
                                Content="Add Sound"
                                Command="{Binding AddSoundCommand}"
                                Width="120"
                                Height="36"
                                Margin="0,0,12,0"/>

                        <Button Grid.Column="2"
                                Content="Delete"
                                Command="{Binding DeleteMarkedSoundsCommand}"
                                Width="90"
                                Height="36"/>
                    </Grid>

                    <ListView Grid.Row="2"
                              ItemsSource="{Binding SoundsView}"
                              Background="Transparent"
                              BorderThickness="0">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="280"/>
                                <GridViewColumn Header="Category" DisplayMemberBinding="{Binding Category}" Width="160"/>
                                <GridViewColumn Header="Plays" DisplayMemberBinding="{Binding PlayCount}" Width="80"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>

            <!-- Settings Page -->
            <Border Width="930"
                    Height="470"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="300,220,0,0">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource GlassPanel}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentPage}" Value="Settings">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="30">

                        <TextBlock Text="SETTINGS"
                                   Foreground="#00D8FF"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="Audio Routing"
                                   Foreground="#DDEAFF"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,8,0,8"/>

                        <TextBlock Text="Output Device"
                                   Foreground="#A1B2D2"
                                   FontSize="14"
                                   Margin="0,0,0,6"/>

                        <TextBlock Text="{Binding CurrentOutputDevice}"
                                   Foreground="#DDEAFF"
                                   FontSize="16"
                                   Margin="0,0,0,14"/>

                        <TextBlock Text="Input Device"
                                   Foreground="#A1B2D2"
                                   FontSize="14"
                                   Margin="0,0,0,6"/>

                        <TextBlock Text="{Binding CurrentInputDevice}"
                                   Foreground="#DDEAFF"
                                   FontSize="16"
                                   Margin="0,0,0,14"/>

                        <TextBlock Text="{Binding RoutingStatus}"
                                   Foreground="#A1B2D2"
                                   FontSize="13"
                                   Margin="0,0,0,14"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Button Content="Auto Configure"
                                    Command="{Binding AutoConfigureAudioCommand}"
                                    Width="150"
                                    Height="40"
                                    Margin="0,0,12,0"/>

                            <Button Content="Test Routing"
                                    Command="{Binding TestRoutingCommand}"
                                    Width="150"
                                    Height="40"
                                    Margin="0,0,12,0"/>

                            <Button Content="Audio Setup"
                                    AutomationProperties.AutomationId="SettingsOpenAudioSetupWizardButton"
                                    Command="{Binding OpenSetupWizardCommand}"
                                    Width="150"
                                    Height="40"/>
                        </StackPanel>

                        <TextBlock Text="Keyboard Layout"
                                   Foreground="#A1B2D2"
                                   FontSize="14"
                                   Margin="0,8,0,6"/>

                        <ComboBox ItemsSource="{Binding KeyboardLayoutOptions}"
                                  SelectedItem="{Binding KeyboardLayout}"
                                  Width="200"
                                  HorizontalAlignment="Left"
                                  Margin="0,0,0,20"/>

                        <TextBlock Text="Advanced Settings"
                                   Foreground="#DDEAFF"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,8,0,8"/>

                        <Button Content="Calibration"
                                Click="OpenCalibrationButton_Click"
                                Width="150"
                                Height="40"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,16"/>

                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="#A1B2D2"
                                   FontSize="13"
                                   Margin="0,20,0,0"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Page Tabs (overlaid on hero section, rendered after content for click priority) -->
            <Border Width="930"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    Margin="300,164,0,0" Padding="6,6,6,0">
                <StackPanel Orientation="Horizontal">

                    <!-- Home Tab -->
                    <Border x:Name="HomeTabBorder" CornerRadius="8" Padding="0" ToolTip="Home"
                            Cursor="Hand" MouseLeftButtonDown="NavigateHome_Click" Margin="0,0,4,0">
                        <StackPanel>
                            <TextBlock Text="&#x2302;  Home" FontSize="16" FontWeight="SemiBold" Padding="16,10,16,2"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#506078"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentPage}" Value="Home">
                                                <Setter Property="Foreground" Value="#DDEAFF"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Border Height="3" CornerRadius="1.5" HorizontalAlignment="Stretch">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentPage}" Value="Home">
                                                <Setter Property="Background" Value="#00D8FF"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </StackPanel>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="Home">
                                        <Setter Property="Background" Value="#1800D8FF"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <!-- Sound Library Tab -->
                    <Border x:Name="SoundLibTabBorder" CornerRadius="8" Padding="0" ToolTip="Sound Library"
                            Cursor="Hand" MouseLeftButtonDown="NavigateSoundLibrary_Click" Margin="0,0,4,0">
                        <StackPanel>
                            <TextBlock Text="&#x266B;  Sound Library" FontSize="16" FontWeight="SemiBold" Padding="16,10,16,2"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#506078"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentPage}" Value="SoundLibrary">
                                                <Setter Property="Foreground" Value="#DDEAFF"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Border Height="3" CornerRadius="1.5" HorizontalAlignment="Stretch">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentPage}" Value="SoundLibrary">
                                                <Setter Property="Background" Value="#00D8FF"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </StackPanel>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="SoundLibrary">
                                        <Setter Property="Background" Value="#1800D8FF"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <!-- Effects Tab -->
                    <Border x:Name="EffectsTabBorder" CornerRadius="8" Padding="0" ToolTip="Effects"
                            Cursor="Hand" MouseLeftButtonDown="NavigateEffects_Click" Margin="0,0,4,0">
                        <StackPanel>
                            <TextBlock Text="&#x1F39A;  Effects" FontSize="16" FontWeight="SemiBold" Padding="16,10,16,2"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#506078"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentPage}" Value="Effects">
                                                <Setter Property="Foreground" Value="#DDEAFF"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Border Height="3" CornerRadius="1.5" HorizontalAlignment="Stretch">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentPage}" Value="Effects">
                                                <Setter Property="Background" Value="#00D8FF"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </StackPanel>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="Effects">
                                        <Setter Property="Background" Value="#1800D8FF"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <!-- Settings Tab -->
                    <Border x:Name="SettingsTabBorder" CornerRadius="8" Padding="0" ToolTip="Settings"
                            Cursor="Hand" MouseLeftButtonDown="NavigateSettings_Click">
                        <StackPanel>
                            <TextBlock Text="&#x2699;  Settings" FontSize="16" FontWeight="SemiBold" Padding="16,10,16,2"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#506078"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentPage}" Value="Settings">
                                                <Setter Property="Foreground" Value="#DDEAFF"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Border Height="3" CornerRadius="1.5" HorizontalAlignment="Stretch">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentPage}" Value="Settings">
                                                <Setter Property="Background" Value="#00D8FF"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </StackPanel>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="Settings">
                                        <Setter Property="Background" Value="#1800D8FF"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                </StackPanel>
            </Border>

            <!-- Title Bar -->

                <Border HorizontalAlignment="Stretch"
                    Height="44"
                    VerticalAlignment="Top"
                    Margin="0,0,0,0"
                    Style="{StaticResource WindowChromeBar}"
                    CornerRadius="0">
                <Grid Margin="18,0,14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="SOUNDFX STUDIO"
                               VerticalAlignment="Center"
                               Foreground="#F2F2F2"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <Button Grid.Column="1"
                            Width="110"
                            Height="32"
                            Click="OpenCalibrationButton_Click"
                            VerticalAlignment="Center"
                            Margin="0,0,12,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="#00D8FF"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="CalBorder" CornerRadius="8"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="1">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="CalBorder" Property="Background" Value="#2200D8FF"/>
                                                    <Setter TargetName="CalBorder" Property="BorderBrush" Value="#00D8FF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2699;" FontSize="13" Foreground="#00D8FF" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Calibration" FontSize="13" Foreground="#DDEAFF" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Style="{StaticResource WindowChromeButton}"
                                Content="&#x2212;"
                                FontSize="17"
                                Click="MinimizeButton_Click"/>
                        <Button Style="{StaticResource WindowChromeCloseButton}"
                                Content="&#x2715;"
                                FontSize="15"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>



            <!-- Sidebar -->

            <Border Style="{StaticResource GlassPanel}"
                    Width="250"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="35,170,0,0"
                    ClipToBounds="True">

                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="20">

                        <!-- QUICK ACTIONS -->
                        <TextBlock Text="QUICK ACTIONS" FontSize="12" FontWeight="SemiBold" Foreground="#00D8FF" Margin="0,0,0,8"/>

                        <Border Background="#0C1424" BorderBrush="#1B3157" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,12">
                            <StackPanel>

                                <Button Click="OpenKeyboardWindowButton_Click" Height="44" Margin="0,0,0,8"
                                        Background="#101A2A" BorderBrush="#243A63" BorderThickness="1">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="BtnBorder" CornerRadius="10" Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="BtnBorder" Property="Background" Value="#152542"/>
                                                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="#00D8FF"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x2328;" FontSize="20" Foreground="#00D8FF" Width="28" VerticalAlignment="Center"/>
                                        <TextBlock Text="Open Keyboard" FontSize="14" Foreground="#DDEAFF" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Height="44" Margin="0,0,0,8"
                                        Background="#101A2A" BorderBrush="#243A63" BorderThickness="1"
                                        Command="{Binding AddSoundCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="BtnBorder" CornerRadius="10" Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="BtnBorder" Property="Background" Value="#152542"/>
                                                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="#AA45FF"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="+" FontSize="26" FontWeight="Bold" Foreground="#AA45FF" Width="28" VerticalAlignment="Center"/>
                                        <TextBlock Text="Add Sound" FontSize="14" Foreground="#DDEAFF" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Height="44" Margin="0,0,0,8"
                                        Background="#101A2A" BorderBrush="#243A63" BorderThickness="1"
                                        Command="{Binding AddMultipleSoundsCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="BtnBorder" CornerRadius="10" Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="BtnBorder" Property="Background" Value="#152542"/>
                                                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="#FF44CC"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x2B07;" FontSize="20" Foreground="#FF44CC" Width="28" VerticalAlignment="Center"/>
                                        <TextBlock Text="Import Sounds" FontSize="14" Foreground="#DDEAFF" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Height="44"
                                        Background="#101A2A" BorderBrush="#243A63" BorderThickness="1"
                                        Click="OpenCalibrationButton_Click">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="BtnBorder" CornerRadius="10" Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="BtnBorder" Property="Background" Value="#152542"/>
                                                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="#00D8FF"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x1F50A;" FontSize="20" Foreground="#00D8FF" Width="28" VerticalAlignment="Center"/>
                                        <TextBlock Text="Configure Audio" FontSize="14" Foreground="#DDEAFF" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- PROFILE -->
                        <TextBlock Text="PROFILE" FontSize="12" FontWeight="SemiBold" Foreground="#00D8FF" Margin="0,4,0,8"/>
                        <Border Background="#0C1424" BorderBrush="#1B3157" BorderThickness="1" CornerRadius="10" Padding="10,6" Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x2605;" FontSize="18" Foreground="#FFD700" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ComboBox ItemsSource="{Binding KeyboardLayoutOptions}"
                                          SelectedItem="{Binding KeyboardLayout}"
                                          Background="Transparent" Foreground="#DDEAFF" BorderBrush="#1B3157"
                                          BorderThickness="1" Padding="8,8" FontSize="14" MinWidth="170"
                                          VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- AUDIO STATUS -->
                        <TextBlock Text="AUDIO STATUS" FontSize="12" FontWeight="SemiBold" Foreground="#00D8FF" Margin="0,4,0,8"/>

                        <Border Background="#0C1424" BorderBrush="#1B3157" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Width="8" Height="8" Fill="#2CE96E" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Output" FontSize="11" Foreground="#7F899C"/>
                                        <TextBlock Text="{Binding CurrentOutputDevice}" FontSize="13" Foreground="#DDEAFF"/>
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Width="8" Height="8" Fill="#2CE96E" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Input" FontSize="11" Foreground="#7F899C"/>
                                        <TextBlock Text="{Binding CurrentInputDevice}" FontSize="13" Foreground="#DDEAFF"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="{Binding RoutingStatus}" FontSize="11" Foreground="#7F899C" Margin="0,0,0,10"/>
                                <Button Height="40" Background="#101827" BorderBrush="#22385D" BorderThickness="1"
                                        Command="{Binding TestRoutingCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="BtnBorder" CornerRadius="8" Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="BtnBorder" Property="Background" Value="#152542"/>
                                                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="#00D8FF"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x25B6;" FontSize="12" Foreground="#00D8FF" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Test Routing" FontSize="14" Foreground="#DDEAFF" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Footer Bar -->
            <Border HorizontalAlignment="Left" VerticalAlignment="Bottom"
                    Margin="35,0,35,35" Width="1256"
                    Background="#0C1424" BorderBrush="#1B3157" BorderThickness="1" CornerRadius="12"
                    Padding="18,10,18,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#x266B;" FontSize="14" Foreground="#00D8FF" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StatusText}" Foreground="#7F899C" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1" Text="SOUNDFX STUDIO" Foreground="#33506A" FontSize="11"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>