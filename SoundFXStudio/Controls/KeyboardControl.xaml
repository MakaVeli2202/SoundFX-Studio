<UserControl x:Class="SoundFXStudio.Controls.KeyboardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:SoundFXStudio.Controls"
             xmlns:converters="clr-namespace:SoundFXStudio.Converters"
             xmlns:effects="clr-namespace:System.Windows.Media.Effects;assembly=PresentationCore"
             Background="Transparent"
             Width="1536"
             Height="1024"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#F5F7FB" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Opacity" Value="0.45" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid SnapsToDevicePixels="True" Background="Transparent">
                            <Border x:Name="GlowLayer"
                                    Margin="-2"
                                    CornerRadius="12"
                                    Background="Transparent"
                                    BorderBrush="#22D3FF"
                                    BorderThickness="2"
                                    Opacity="0"
                                    IsHitTestVisible="False" />

                            <Border x:Name="Frame"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                    Opacity="{TemplateBinding Opacity}" />

                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"
                                              Margin="0"
                                              RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="1" />
                                <Setter TargetName="GlowLayer" Property="Opacity" Value="1" />
                                <Setter TargetName="GlowLayer" Property="Effect">
                                    <Setter.Value>
                                        <effects:DropShadowEffect Color="#22D3FF" BlurRadius="10" ShadowDepth="0" Opacity="0.7" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="1" />
                                <Setter TargetName="GlowLayer" Property="Opacity" Value="1" />
                                <Setter TargetName="GlowLayer" Property="Effect">
                                    <Setter.Value>
                                        <effects:DropShadowEffect Color="#22D3FF" BlurRadius="12" ShadowDepth="0" Opacity="0.8" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <DataTrigger Binding="{Binding HasAssignment}" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                                <Setter TargetName="Frame" Property="Opacity" Value="0.45" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding HasAssignment}" Value="True">
                                <Setter Property="Opacity" Value="0.95" />
                                <Setter TargetName="Frame" Property="Opacity" Value="0.95" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="Opacity" Value="1" />
                                <Setter TargetName="GlowLayer" Property="Opacity" Value="1" />
                                <Setter TargetName="GlowLayer" Property="Effect">
                                    <Setter.Value>
                                        <effects:DropShadowEffect Color="#FF4D8D" BlurRadius="10" ShadowDepth="0" Opacity="0.7" />
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="Transparent"
            CornerRadius="0"
            BorderBrush="Transparent"
            BorderThickness="0"
            Padding="0">
        <Grid Width="1536" Height="1024">
            <Image Source="/Assets/Keyboards/SoundFXKeyBoard.png"
                   Stretch="Fill"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"
                   IsHitTestVisible="False" />

            <ItemsControl ItemsSource="{Binding ItemsSource, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          Panel.ZIndex="1">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <controls:KeyboardLayoutPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Command="{Binding DataContext.KeyClickedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                AutomationProperties.AutomationId="{Binding Id}"
                            AutomationProperties.Name="{Binding AutomationName}"
                                AllowDrop="True"
                                Drop="KeyButton_Drop"
                                DragOver="KeyButton_DragOver"
                                Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="➕ Assign Sound"
                                              Command="{Binding PlacementTarget.Tag.AssignSelectedSoundToKeyCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <MenuItem Header="❌ Remove Sound"
                                              Command="{Binding PlacementTarget.Tag.RemoveSoundFromKeyCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <MenuItem Header="🖼️ Set Image"
                                              Command="{Binding PlacementTarget.Tag.ChooseKeyImageCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <MenuItem Header="❌ Remove Image"
                                              Command="{Binding PlacementTarget.Tag.RemoveKeyImageCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <Separator />
                                    <MenuItem Header="📝 Rename Binding"
                                              Command="{Binding PlacementTarget.Tag.RenameBindingCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <Separator />
                                    <MenuItem Header="🔊 Volume"
                                              Command="{Binding PlacementTarget.Tag.ChangeKeyVolumeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <MenuItem Header="🔁 Toggle Loop"
                                              Command="{Binding PlacementTarget.Tag.ToggleKeyLoopCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <MenuItem Header="⏹️ Stop Playback"
                                              Command="{Binding PlacementTarget.Tag.StopKeyPlaybackCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <Separator />
                                    <MenuItem Header="📋 Duplicate Binding"
                                              Command="{Binding PlacementTarget.Tag.DuplicateBindingCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                </ContextMenu>
                            </Button.ContextMenu>

                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasAssignment}" Value="True">
                                            <Setter Property="Opacity" Value="0.94" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding HasAssignment}" Value="False">
                                            <Setter Property="Opacity" Value="0.45" />
                                        </DataTrigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.4" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Grid.RowSpan="3"
                                        CornerRadius="10"
                                        Background="#09000000"
                                        Opacity="0.06" />

                                <Border Grid.RowSpan="3"
                                        Width="4"
                                        HorizontalAlignment="Left"
                                        CornerRadius="2"
                                        Background="{Binding CategoryAccentColor}"
                                        Opacity="0.85"
                                        Visibility="{Binding HasAssignment, Converter={StaticResource BoolToVisibilityConverter}}" />

                                <Grid Grid.Row="1"
                                      Margin="4,1,4,1"
                                      Visibility="{Binding HasAssignment, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Border CornerRadius="8"
                                            Background="#12000000"
                                            ClipToBounds="True">
                                        <Grid>
                                            <Image Source="{Binding ImagePath}"
                                                   Stretch="Fill"
                                                   Opacity="0.9"
                                                   SnapsToDevicePixels="True" />
                                            <Border>
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#18000000" Offset="0" />
                                                        <GradientStop Color="#64000000" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <Grid Grid.RowSpan="3" Margin="6,4,6,4">
                                    <TextBlock Text="{Binding DisplayLabel}"
                                               Foreground="#FFFFFF"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               TextAlignment="Center"
                                               TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis"
                                               Opacity="1">
                                        <TextBlock.Effect>
                                            <DropShadowEffect Color="#000000" BlurRadius="3" ShadowDepth="0" Opacity="0.85" />
                                        </TextBlock.Effect>
                                    </TextBlock>
                                </Grid>

                                <Border Grid.Row="2"
                                        Margin="4,0,4,2"
                                        CornerRadius="6"
                                        Background="#7A000000"
                                        Visibility="{Binding HasAssignment, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel Margin="4,2,4,2">
                                        <TextBlock Text="{Binding AssignedSoundName}"
                                                   Foreground="#FFFFFFFF"
                                                   FontSize="9"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Left"
                                                   TextAlignment="Left"
                                                   TextWrapping="NoWrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   Opacity="1">
                                            <TextBlock.Effect>
                                                <DropShadowEffect Color="#000000" BlurRadius="4" ShadowDepth="0" Opacity="0.9" />
                                            </TextBlock.Effect>
                                        </TextBlock>
                                        <TextBlock Text="{Binding AssignmentName}"
                                                   Foreground="#FFF0F4FF"
                                                   FontSize="8"
                                                   HorizontalAlignment="Left"
                                                   TextAlignment="Left"
                                                   TextWrapping="NoWrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   Opacity="1">
                                            <TextBlock.Effect>
                                                <DropShadowEffect Color="#000000" BlurRadius="3" ShadowDepth="0" Opacity="0.85" />
                                            </TextBlock.Effect>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Border>
</UserControl>