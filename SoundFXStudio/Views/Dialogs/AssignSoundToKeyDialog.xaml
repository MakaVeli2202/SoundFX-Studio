<Window x:Class="SoundFXStudio.Views.Dialogs.AssignSoundToKeyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Assign Sound"
        Width="600"
        Height="720"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="/Assets/SoundFXStudioLogo.png">

    <Window.Resources>

        <SolidColorBrush x:Key="PanelBrush" Color="#66081428"/>
        <SolidColorBrush x:Key="TextBrush" Color="#EAF1FF"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#A1B2D2"/>

        <Style x:Key="GlassPanel"
               TargetType="Border">

            <Setter Property="CornerRadius"
                    Value="24"/>

            <Setter Property="Background"
                    Value="#66081428"/>

            <Setter Property="BorderBrush"
                    Value="#5580CFFF"/>

            <Setter Property="BorderThickness"
                    Value="1"/>

        </Style>

        <Style x:Key="GlassButton"
               TargetType="Button">

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="Background"
                    Value="#22112233"/>

            <Setter Property="BorderBrush"
                    Value="#3370AFFF"/>

            <Setter Property="BorderThickness"
                    Value="1"/>

            <Setter Property="Cursor"
                    Value="Hand"/>

            <Setter Property="Height"
                    Value="40"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="ButtonBorder"
                                CornerRadius="14"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">

                                <Setter TargetName="ButtonBorder"
                                        Property="BorderBrush"
                                        Value="#00D8FF"/>

                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#2200D8FF"/>

                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">

                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#33FF44CC"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

    </Window.Resources>

    <Border Background="#081428"
            CornerRadius="28"
            ClipToBounds="True">

        <Border.BorderBrush>

            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,0">

                <GradientStop Color="#00D8FF"
                              Offset="0"/>

                <GradientStop Color="#FF44CC"
                              Offset="1"/>

            </LinearGradientBrush>

        </Border.BorderBrush>

        <Border.BorderThickness>2</Border.BorderThickness>

        <Grid Margin="18">

            <Grid.RowDefinitions>

                <RowDefinition Height="75"/>

                <RowDefinition Height="90"/>

                <RowDefinition Height="*"/>

                <RowDefinition Height="70"/>

            </Grid.RowDefinitions>

            <!-- HEADER -->

            <Border Grid.Row="0"
                    Style="{StaticResource GlassPanel}">

                <Grid MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="*"/>

                        <ColumnDefinition Width="Auto"/>

                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="18,0">

                        <Image Source="/Assets/SoundFXStudioLogo.png"
                               Width="46"
                               Height="46"/>

                        <StackPanel Margin="12,0,0,0">

                            <TextBlock Text="SOUNDFX STUDIO"
                                       Foreground="#00D8FF"
                                       FontWeight="Bold"/>

                            <TextBlock Text="Assign Sound To Key"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="White"/>

                        </StackPanel>

                    </StackPanel>

                    <Button Grid.Column="1"
                            Width="40"
                            Height="40"
                            Margin="0,10,10,10"
                            Content="✕"
                            Background="#55203030"
                            BorderBrush="#FF5A7A"
                            Click="CloseButton_Click"/>

                </Grid>

            </Border>

            <!-- SEARCH -->

            <Border Grid.Row="1"
                    Style="{StaticResource GlassPanel}"
                    Margin="0,14,0,14">

                <StackPanel Margin="16">

                    <TextBlock Text="Search Sounds"
                               Foreground="#00D8FF"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <TextBox Height="40"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                </StackPanel>

            </Border>

            <!-- SOUND LIST -->

            <Border Grid.Row="2"
                    Style="{StaticResource GlassPanel}">

                <Grid>

                    <Grid.RowDefinitions>

                        <RowDefinition Height="*"/>

                        <RowDefinition Height="Auto"/>

                    </Grid.RowDefinitions>

                    <ListBox ItemsSource="{Binding FilteredSounds}"
                             SelectedItem="{Binding SelectedSound, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{StaticResource TextBrush}">

                        <ListBox.ItemTemplate>

                            <DataTemplate>

                                <Border Background="#22112233"
                                        BorderBrush="#3370AFFF"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Margin="0,0,0,10"
                                        Padding="12">

                                    <Grid>

                                        <Grid.ColumnDefinitions>

                                            <ColumnDefinition Width="65"/>

                                            <ColumnDefinition Width="*"/>

                                        </Grid.ColumnDefinitions>

                                        <Border Width="56"
                                                Height="56"
                                                CornerRadius="12"
                                                Background="#0A0F18"
                                                ClipToBounds="True">

                                            <Image Source="{Binding ImagePath}"
                                                   Stretch="UniformToFill"/>

                                        </Border>

                                        <StackPanel Grid.Column="1"
                                                    Margin="12,0,0,0"
                                                    VerticalAlignment="Center">

                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextBrush}"
                                                       TextTrimming="CharacterEllipsis"/>

                                            <TextBlock Text="{Binding Category}"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       Margin="0,3,0,0"/>

                                            <TextBlock Text="{Binding FilePath}"
                                                       Foreground="#8AA0BC"
                                                       FontSize="11"
                                                       Margin="0,3,0,0"
                                                       TextTrimming="CharacterEllipsis"/>

                                        </StackPanel>

                                    </Grid>

                                </Border>

                            </DataTemplate>

                        </ListBox.ItemTemplate>

                    </ListBox>

                    <TextBlock Grid.Row="1"
                               Text="No sounds match the current search."
                               Foreground="{StaticResource MutedBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"
                               Visibility="{Binding EmptyStateVisibility}"/>

                </Grid>

            </Border>

            <!-- FOOTER -->

            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">

                <Button Content="Cancel"
                        Width="120"
                        Margin="0,0,10,0"
                        Style="{StaticResource GlassButton}"
                        Click="CancelButton_Click"/>

                <Button Content="Assign"
                        Width="140"
                        FontWeight="Bold"
                        Foreground="#081428"
                        Click="AssignButton_Click">

                    <Button.Background>

                        <LinearGradientBrush StartPoint="0,0"
                                             EndPoint="1,0">

                            <GradientStop Color="#00D8FF"
                                          Offset="0"/>

                            <GradientStop Color="#FF44CC"
                                          Offset="1"/>

                        </LinearGradientBrush>

                    </Button.Background>

                </Button>

            </StackPanel>

        </Grid>

    </Border>

</Window>