<Window x:Class="SoundFXStudio.Views.Dialogs.HotkeyCaptureDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Capture Hotkey"
        Width="460"
        Height="240"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        Loaded="Window_Loaded"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Border Background="#111827" CornerRadius="18" BorderBrush="#2E3A52" BorderThickness="1" Padding="18">
        <StackPanel>
            <TextBlock Text="Record a shortcut" FontSize="22" FontWeight="Bold" />
            <TextBlock Text="Click Record, press the keys you want, then press Enter to save." TextWrapping="Wrap" Opacity="0.78" Margin="0,6,0,16" />

            <Border Background="#0B1220" CornerRadius="14" Padding="14" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Current shortcut" Opacity="0.72" />
                    <TextBlock Text="{Binding CapturedHotkey}" FontSize="24" FontWeight="Bold" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="RecordButton" Content="Record" Width="96" Margin="0,0,8,0" Click="RecordButton_Click" />
                <Button x:Name="DoneButton" Content="Done" Width="96" Margin="0,0,8,0" Click="DoneButton_Click" IsDefault="True" IsEnabled="False" />
                <Button x:Name="CancelButton" Content="Cancel" Width="96" Click="CancelButton_Click" IsCancel="True" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>