<Window x:Class="SoundFXStudio.Views.Dialogs.TextEntryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Text"
        Width="460"
        Height="250"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#08101D"
        WindowStyle="None"
        Icon="/Assets/SoundFXStudioLogo.png">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#101A2D" />
        <SolidColorBrush x:Key="SecondaryPanelBrush" Color="#0E1728" />
        <SolidColorBrush x:Key="BorderBrushTheme" Color="#2E4568" />
        <SolidColorBrush x:Key="TextBrush" Color="#EAF1FF" />
        <SolidColorBrush x:Key="MutedBrush" Color="#A4B2C9" />
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource SecondaryPanelBrush}" BorderBrush="#2E4568" BorderThickness="1" CornerRadius="16" Padding="12" Margin="0,0,0,14">
            <Grid MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="42" Height="42" CornerRadius="12" Background="#0A0A0A" BorderBrush="#303030" BorderThickness="1" Padding="4" Margin="0,0,12,0">
                        <Image Source="/Assets/SoundFXStudioLogo.png" Stretch="Uniform" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="SoundFX Studio" FontSize="13" FontWeight="Bold" Foreground="{StaticResource MutedBrush}" />
                        <TextBlock Text="{Binding DialogTitle}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
                    </StackPanel>
                </StackPanel>
                <Button Grid.Column="1" Content="✕" Width="40" Height="30" VerticalAlignment="Top" Background="#3C1B2A" BorderBrush="#7B3C57" Click="CloseButton_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource SecondaryPanelBrush}" BorderBrush="{StaticResource BorderBrushTheme}" BorderThickness="1" CornerRadius="14" Padding="16">
            <StackPanel>
                <TextBlock Text="{Binding PromptText}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,0,0,12" />
                <TextBox x:Name="ValueTextBox" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Height="38" VerticalContentAlignment="Center" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Clear" Width="100" Margin="0,0,10,0" Click="ClearButton_Click" Visibility="{Binding ClearButtonVisibility}" Background="#2A3D5D" Foreground="{StaticResource TextBrush}" />
            <Button Content="Cancel" Width="100" Margin="0,0,10,0" Click="CancelButton_Click" Background="#2A3D5D" Foreground="{StaticResource TextBrush}" />
            <Button Content="Save" Width="100" Click="SaveButton_Click" Background="#5AD8FF" Foreground="#08101D" FontWeight="Bold" />
        </StackPanel>
    </Grid>
</Window>