<Window x:Class="SoundFXStudio.Views.Dialogs.KeyboardCalibrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SoundFXStudio.Controls"
        Title="Keyboard Calibration"
        Width="1240"
        Height="860"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Icon="/Assets/SoundFXStudioLogo.png"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <Style x:Key="GlassPanel" TargetType="Border">
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Background" Value="#66081428"/>
            <Setter Property="BorderBrush" Value="#5580CFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <SolidColorBrush x:Key="BorderBrushTheme" Color="#2E4568"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#A4B2C9"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EAF1FF"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="#EAF1FF"/>
            <Setter Property="Background" Value="#0E1728"/>
            <Setter Property="BorderBrush" Value="#2E4568"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#EAF1FF"/>
            <Setter Property="Background" Value="#0E1728"/>
            <Setter Property="BorderBrush" Value="#2E4568"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#EAF1FF"/>
            <Setter Property="Background" Value="#16243B"/>
            <Setter Property="BorderBrush" Value="#35527A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#5AD8FF"/>
                    <Setter Property="Background" Value="#1D2F4A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StepperButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="CyberButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#22112233"/>
            <Setter Property="BorderBrush" Value="#3370AFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Border Background="#081428"
            CornerRadius="28"
            ClipToBounds="True"
            BorderThickness="2">


        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="#00D8FF" Offset="0"/>
                <GradientStop Color="#FF44CC" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0">
                    <Image Source="/Assets/UI/MainDashboardLogo.png"
                           Height="42"
                           Stretch="Uniform"
                           Margin="0,0,14,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="KEYBOARD CALIBRATION"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#00D8FF"/>
                        <TextBlock Text="General + Per-Key Layout Editing"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </StackPanel>
                <Button Grid.Column="1"
                        Width="38"
                        Height="28"
                        Padding="0"
                        Content="&#x2715;"
                        Background="#3C1B2A"
                        BorderBrush="#7B3C57"
                        Click="CloseButton_Click"
                        VerticalAlignment="Center"
                        Margin="0,0,18,0"/>
            </Grid>

            <Grid Grid.Row="1" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="390"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Border Style="{StaticResource GlassPanel}" BorderThickness="1" CornerRadius="14" Padding="14" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="General" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

                                <TextBlock Text="Move All Left/Right (X)" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                                <DockPanel Margin="0,0,0,8">
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25C0;" Tag="PreviewOffsetX:-1" Click="NudgeValue_Click"/>
                                        <TextBox Width="72" Margin="6,0" Text="{Binding PreviewOffsetX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25B6;" Tag="PreviewOffsetX:1" Click="NudgeValue_Click"/>
                                    </StackPanel>
                                    <Slider Minimum="-250" Maximum="250" Value="{Binding PreviewOffsetX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TickFrequency="1" Margin="0,0,8,0"/>
                                </DockPanel>

                                <TextBlock Text="Move All Up/Down (Y)" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                                <DockPanel Margin="0,0,0,8">
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25C0;" Tag="PreviewOffsetY:-1" Click="NudgeValue_Click"/>
                                        <TextBox Width="72" Margin="6,0" Text="{Binding PreviewOffsetY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25B6;" Tag="PreviewOffsetY:1" Click="NudgeValue_Click"/>
                                    </StackPanel>
                                    <Slider Minimum="-250" Maximum="250" Value="{Binding PreviewOffsetY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TickFrequency="1" Margin="0,0,8,0"/>
                                </DockPanel>

                                <TextBlock Text="Gap Between Buttons (Horizontal)" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                                <DockPanel Margin="0,0,0,8">
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25C0;" Tag="PreviewGapX:-0.25" Click="NudgeValue_Click"/>
                                        <TextBox Width="72" Margin="6,0" Text="{Binding PreviewGapX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25B6;" Tag="PreviewGapX:0.25" Click="NudgeValue_Click"/>
                                    </StackPanel>
                                    <Slider Minimum="-10" Maximum="20" Value="{Binding PreviewGapX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TickFrequency="0.25" Margin="0,0,8,0"/>
                                </DockPanel>

                                <TextBlock Text="Gap Between Rows (Vertical)" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                                <DockPanel Margin="0,0,0,8">
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25C0;" Tag="PreviewGapY:-0.25" Click="NudgeValue_Click"/>
                                        <TextBox Width="72" Margin="6,0" Text="{Binding PreviewGapY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25B6;" Tag="PreviewGapY:0.25" Click="NudgeValue_Click"/>
                                    </StackPanel>
                                    <Slider Minimum="-10" Maximum="20" Value="{Binding PreviewGapY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TickFrequency="0.25" Margin="0,0,8,0"/>
                                </DockPanel>

                                <TextBlock Text="Key Unit" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                                <DockPanel Margin="0,0,0,8">
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25C0;" Tag="PreviewKeyUnit:-0.5" Click="NudgeValue_Click"/>
                                        <TextBox Width="72" Margin="6,0" Text="{Binding PreviewKeyUnit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25B6;" Tag="PreviewKeyUnit:0.5" Click="NudgeValue_Click"/>
                                    </StackPanel>
                                    <Slider Minimum="20" Maximum="80" Value="{Binding PreviewKeyUnit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TickFrequency="0.5" Margin="0,0,8,0"/>
                                </DockPanel>

                                <TextBlock Text="Inner Width Inset %" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                                <DockPanel Margin="0,0,0,8">
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25C0;" Tag="PreviewInnerInsetXPercent:-1" Click="NudgeValue_Click"/>
                                        <TextBox Width="72" Margin="6,0" Text="{Binding PreviewInnerInsetXPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25B6;" Tag="PreviewInnerInsetXPercent:1" Click="NudgeValue_Click"/>
                                    </StackPanel>
                                    <Slider Minimum="0" Maximum="45" Value="{Binding PreviewInnerInsetXPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TickFrequency="1" Margin="0,0,8,0"/>
                                </DockPanel>

                                <TextBlock Text="Inner Height Inset %" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                                <DockPanel Margin="0,0,0,8">
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25C0;" Tag="PreviewInnerInsetYPercent:-1" Click="NudgeValue_Click"/>
                                        <TextBox Width="72" Margin="6,0" Text="{Binding PreviewInnerInsetYPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25B6;" Tag="PreviewInnerInsetYPercent:1" Click="NudgeValue_Click"/>
                                    </StackPanel>
                                    <Slider Minimum="0" Maximum="45" Value="{Binding PreviewInnerInsetYPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TickFrequency="1" Margin="0,0,8,0"/>
                                </DockPanel>

                                <TextBlock Text="Inner Push X %" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                                <DockPanel Margin="0,0,0,8">
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25C0;" Tag="PreviewInnerOffsetXPercent:-1" Click="NudgeValue_Click"/>
                                        <TextBox Width="72" Margin="6,0" Text="{Binding PreviewInnerOffsetXPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25B6;" Tag="PreviewInnerOffsetXPercent:1" Click="NudgeValue_Click"/>
                                    </StackPanel>
                                    <Slider Minimum="-30" Maximum="30" Value="{Binding PreviewInnerOffsetXPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TickFrequency="1" Margin="0,0,8,0"/>
                                </DockPanel>

                                <TextBlock Text="Inner Push Y %" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25C0;" Tag="PreviewInnerOffsetYPercent:-1" Click="NudgeValue_Click"/>
                                        <TextBox Width="72" Margin="6,0" Text="{Binding PreviewInnerOffsetYPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25B6;" Tag="PreviewInnerOffsetYPercent:1" Click="NudgeValue_Click"/>
                                    </StackPanel>
                                    <Slider Minimum="-30" Maximum="30" Value="{Binding PreviewInnerOffsetYPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TickFrequency="1" Margin="0,0,8,0"/>
                                </DockPanel>

                                <TextBlock Text="Lock Lamps" FontSize="18" FontWeight="Bold" Margin="0,10,0,8"/>
                                <TextBlock Text="Calibrate the three lock indicators over the numpad." TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,12"/>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Caps Lock" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25C0;" Tag="CapsLockIndicatorOffsetX:-1" Click="NudgeValue_Click"/>
                                        <TextBox Width="60" Margin="4,0" Text="{Binding CapsLockIndicatorOffsetX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25B6;" Tag="CapsLockIndicatorOffsetX:1" Click="NudgeValue_Click"/>
                                        <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25B2;" Tag="CapsLockIndicatorOffsetY:-1" Click="NudgeValue_Click" Margin="6,0,0,0"/>
                                        <TextBox Width="60" Margin="4,0" Text="{Binding CapsLockIndicatorOffsetY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25BC;" Tag="CapsLockIndicatorOffsetY:1" Click="NudgeValue_Click"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Num Lock" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25C0;" Tag="NumLockIndicatorOffsetX:-1" Click="NudgeValue_Click"/>
                                        <TextBox Width="60" Margin="4,0" Text="{Binding NumLockIndicatorOffsetX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25B6;" Tag="NumLockIndicatorOffsetX:1" Click="NudgeValue_Click"/>
                                        <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25B2;" Tag="NumLockIndicatorOffsetY:-1" Click="NudgeValue_Click" Margin="6,0,0,0"/>
                                        <TextBox Width="60" Margin="4,0" Text="{Binding NumLockIndicatorOffsetY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25BC;" Tag="NumLockIndicatorOffsetY:1" Click="NudgeValue_Click"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Scroll Lock" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25C0;" Tag="ScrollLockIndicatorOffsetX:-1" Click="NudgeValue_Click"/>
                                        <TextBox Width="60" Margin="4,0" Text="{Binding ScrollLockIndicatorOffsetX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25B6;" Tag="ScrollLockIndicatorOffsetX:1" Click="NudgeValue_Click"/>
                                        <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25B2;" Tag="ScrollLockIndicatorOffsetY:-1" Click="NudgeValue_Click" Margin="6,0,0,0"/>
                                        <TextBox Width="60" Margin="4,0" Text="{Binding ScrollLockIndicatorOffsetY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25BC;" Tag="ScrollLockIndicatorOffsetY:1" Click="NudgeValue_Click"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource GlassPanel}" BorderThickness="1" CornerRadius="14" Padding="14" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Cluster Offsets" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBlock Text="Move keyboard groups as a unit." TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,12"/>

                                <ItemsControl ItemsSource="{Binding ClusterItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#2B2B2B" BorderThickness="1" CornerRadius="12" Padding="10" Margin="0,0,0,10">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                                    <Grid Margin="0,0,0,6">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="120"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Offset X" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                                                        <DockPanel Grid.Column="1">
                                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                                <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25C0;" Tag="OffsetX:-1" Click="NudgeValue_Click"/>
                                                                <TextBox Width="72" Margin="6,0" Text="{Binding OffsetX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                                <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25B6;" Tag="OffsetX:1" Click="NudgeValue_Click"/>
                                                            </StackPanel>
                                                        </DockPanel>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,6">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="120"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Offset Y" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                                                        <DockPanel Grid.Column="1">
                                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                                <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25C0;" Tag="OffsetY:-1" Click="NudgeValue_Click"/>
                                                                <TextBox Width="72" Margin="6,0" Text="{Binding OffsetY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                                <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25B6;" Tag="OffsetY:1" Click="NudgeValue_Click"/>
                                                            </StackPanel>
                                                        </DockPanel>
                                                    </Grid>
                                                    <Button Content="Reset Group" Click="ResetSelectedCluster_Click" HorizontalAlignment="Left"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource GlassPanel}" BorderThickness="1" CornerRadius="14" Padding="14" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Special Keys" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBlock Text="Width overrides for special keys." TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}"/>

                                <ItemsControl ItemsSource="{Binding SpecialItems}" Margin="0,12,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#2B2B2B" BorderThickness="1" CornerRadius="12" Padding="10" Margin="0,0,0,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    <DockPanel Grid.Column="1">
                                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                            <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25C0;" Tag="WidthAdjustment:-0.1" Click="NudgeValue_Click"/>
                                                            <TextBox Width="72" Margin="6,0" Text="{Binding WidthAdjustment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                            <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25B6;" Tag="WidthAdjustment:0.1" Click="NudgeValue_Click"/>
                                                        </StackPanel>
                                                    </DockPanel>
                                                    <Button Grid.ColumnSpan="2" Content="Reset Key" HorizontalAlignment="Left" Margin="0,44,0,0" Click="ResetSelectedSpecial_Click"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource GlassPanel}" BorderThickness="1" CornerRadius="14" Padding="14">
                            <StackPanel>
                                <TextBlock Text="Per Key" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                                <TextBlock Text="Click a key in preview, then edit values." Foreground="{StaticResource MutedBrush}" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding SelectedKeyItem.Name, TargetNullValue=No key selected}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,8"/>

                                <StackPanel DataContext="{Binding SelectedKeyItem}">
                                    <TextBlock Text="Offset X" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                                    <DockPanel Margin="0,0,0,6">
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                            <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25C0;" Tag="OffsetX:-1" Click="NudgeValue_Click"/>
                                            <TextBox Width="72" Margin="6,0" Text="{Binding OffsetX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25B6;" Tag="OffsetX:1" Click="NudgeValue_Click"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <TextBlock Text="Offset Y" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                                    <DockPanel Margin="0,0,0,6">
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                            <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25C0;" Tag="OffsetY:-1" Click="NudgeValue_Click"/>
                                            <TextBox Width="72" Margin="6,0" Text="{Binding OffsetY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25B6;" Tag="OffsetY:1" Click="NudgeValue_Click"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <TextBlock Text="Width Adj" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                                    <DockPanel Margin="0,0,0,6">
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                            <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25C0;" Tag="WidthAdjustment:-0.1" Click="NudgeValue_Click"/>
                                            <TextBox Width="72" Margin="6,0" Text="{Binding WidthAdjustment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25B6;" Tag="WidthAdjustment:0.1" Click="NudgeValue_Click"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <TextBlock Text="Height Adj" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                                    <DockPanel Margin="0,0,0,6">
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                            <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25C0;" Tag="HeightAdjustment:-0.1" Click="NudgeValue_Click"/>
                                            <TextBox Width="72" Margin="6,0" Text="{Binding HeightAdjustment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25B6;" Tag="HeightAdjustment:0.1" Click="NudgeValue_Click"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <TextBlock Text="Inner Width Adj %" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                                    <DockPanel Margin="0,0,0,6">
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                            <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25C0;" Tag="InnerInsetXAdjustmentPercent:-1" Click="NudgeValue_Click"/>
                                            <TextBox Width="72" Margin="6,0" Text="{Binding InnerInsetXAdjustmentPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25B6;" Tag="InnerInsetXAdjustmentPercent:1" Click="NudgeValue_Click"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <TextBlock Text="Inner Height Adj %" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                                    <DockPanel Margin="0,0,0,6">
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                            <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25C0;" Tag="InnerInsetYAdjustmentPercent:-1" Click="NudgeValue_Click"/>
                                            <TextBox Width="72" Margin="6,0" Text="{Binding InnerInsetYAdjustmentPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25B6;" Tag="InnerInsetYAdjustmentPercent:1" Click="NudgeValue_Click"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <TextBlock Text="Inner Push X Adj %" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                                    <DockPanel Margin="0,0,0,6">
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                            <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25C0;" Tag="InnerOffsetXAdjustmentPercent:-1" Click="NudgeValue_Click"/>
                                            <TextBox Width="72" Margin="6,0" Text="{Binding InnerOffsetXAdjustmentPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25B6;" Tag="InnerOffsetXAdjustmentPercent:1" Click="NudgeValue_Click"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <TextBlock Text="Inner Push Y Adj %" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                                    <DockPanel>
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                            <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25C0;" Tag="InnerOffsetYAdjustmentPercent:-1" Click="NudgeValue_Click"/>
                                            <TextBox Width="72" Margin="6,0" Text="{Binding InnerOffsetYAdjustmentPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            <Button Style="{StaticResource StepperButtonStyle}" Content="&#x25B6;" Tag="InnerOffsetYAdjustmentPercent:1" Click="NudgeValue_Click"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <Button Content="Reset Selected Key" Margin="0,10,0,0" Click="ResetSelectedKey_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Column="2" Style="{StaticResource GlassPanel}" BorderThickness="1" CornerRadius="14" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Live Preview" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="8,0,0,0">
                                <Button Style="{StaticResource StepperButtonStyle}" Content="-" FontSize="16" Width="32" Height="28" Click="ZoomOut_Click" Margin="0,0,4,0"/>
                                <TextBlock Text="{Binding ZoomLevel, StringFormat='{}{0:0}%'}" VerticalAlignment="Center" Width="48" TextAlignment="Center" FontSize="13"/>
                                <Button Style="{StaticResource StepperButtonStyle}" Content="+" FontSize="16" Width="32" Height="28" Click="ZoomIn_Click" Margin="4,0,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <Border Grid.Row="1" Margin="0,0,0,8" Background="#0B1424" BorderBrush="#2E4568" BorderThickness="1" CornerRadius="12" Padding="8">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                <Viewbox Stretch="Uniform" x:Name="PreviewViewbox">
                                    <controls:KeyboardControl x:Name="PreviewKeyboard"
                                                              ItemsSource="{Binding KeyboardKeys}"
                                                              ButtonScale="{Binding PreviewButtonScale}"
                                                              InnerInsetXPercent="{Binding PreviewInnerInsetXPercent}"
                                                              InnerInsetYPercent="{Binding PreviewInnerInsetYPercent}"
                                                              InnerOffsetXPercent="{Binding PreviewInnerOffsetXPercent}"
                                                              InnerOffsetYPercent="{Binding PreviewInnerOffsetYPercent}"
                                                              KeyClickedCommand="{Binding KeyClickedCommand}"/>
                                </Viewbox>
                            </ScrollViewer>
                        </Border>

                        <StackPanel Grid.Row="2">
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource CyberButton}" Content="Reset All" Width="110" Margin="0,0,8,0" Click="ResetAll_Click"/>
                                <Button Style="{StaticResource CyberButton}" Content="Save" Width="110" Margin="0,0,8,0" Click="SavePermanently_Click"/>
                                <Button Style="{StaticResource CyberButton}" Content="Close" Width="110" Click="CloseButton_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
