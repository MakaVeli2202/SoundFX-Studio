<Window x:Class="SoundFXStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SoundFXStudio.Controls"
        xmlns:converters="clr-namespace:SoundFXStudio.Converters"
        Title="SoundFX Studio"
       
Width="1536"
Height="1024"

        MinWidth="1280"
        MinHeight="760"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Icon="/Assets/SoundFXStudioLogo.png">

    <Window.Resources>

        <SolidColorBrush x:Key="WindowBrush"
                         Color="#050A15"/>

        <SolidColorBrush x:Key="PanelBrush"
                         Color="#0A1222"/>

        <SolidColorBrush x:Key="PanelBrushAlt"
                         Color="#0F1830"/>

        <SolidColorBrush x:Key="TextBrush"
                         Color="#EAF1FF"/>

        <SolidColorBrush x:Key="SecondaryTextBrush"
                         Color="#A1B2D2"/>

        <Style x:Key="SidebarButton" TargetType="Button">

            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="65"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Background" Value="#22112233"/>
            <Setter Property="BorderBrush" Value="#3370AFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>


            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="Border"
                        CornerRadius="14"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">

                            <Grid>

                                <Rectangle Fill="#08FFFFFF"
                                   RadiusX="14"
                                   RadiusY="14"/>

                                <ContentPresenter HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  Margin="22,0,0,0"/>

                            </Grid>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                             Value="True">

                                <Setter TargetName="Border"
                                Property="BorderBrush"
                                Value="#00D8FF"/>

                                <Setter TargetName="Border"
                                Property="Background"
                                Value="#331A2948"/>

                            </Trigger>

                            <Trigger Property="IsPressed"
                             Value="True">

                                <Setter TargetName="Border"
                                Property="Background"
                                Value="#552A4580"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

        <Style x:Key="NeonButton"
       TargetType="Button">

            <Setter Property="Foreground"
            Value="White"/>

            <Setter Property="FontWeight"
            Value="Bold"/>

            <Setter Property="FontSize"
            Value="18"/>

            <Setter Property="Height"
            Value="60"/>

            <Setter Property="Cursor"
            Value="Hand"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border CornerRadius="16">

                            <Border.Background>

                                <LinearGradientBrush StartPoint="0,0"
                                             EndPoint="1,0">

                                    <GradientStop Color="#00BFFF"
                                          Offset="0"/>

                                    <GradientStop Color="#AA45FF"
                                          Offset="1"/>

                                </LinearGradientBrush>

                            </Border.Background>

                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>

                        </Border>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

        <Style x:Key="GlassPanel" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Background" Value="#66081428"/>
            <Setter Property="BorderBrush" Value="#5580CFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="GlassComboBox" TargetType="ComboBox">

            <Setter Property="Foreground" Value="White"/>

            <Setter Property="FontSize" Value="14"/>

            <Setter Property="Background" Value="#44111A2E"/>

            <Setter Property="BorderBrush" Value="#5580CFFF"/>

            <Setter Property="BorderThickness" Value="1"/>

            <Setter Property="Padding" Value="10,4"/>

        </Style>

        <Style x:Key="WindowControlButtonStyle" TargetType="Button">

            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#22112233"/>
            <Setter Property="BorderBrush" Value="#3370AFFF"/>
            <Setter Property="BorderThickness" Value="1"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="Border"
                        CornerRadius="10"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">

                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">

                                <Setter TargetName="Border"
                                        Property="Background"
                                        Value="#1100D8FF"/>

                                <Setter TargetName="Border"
                                        Property="BorderBrush"
                                        Value="#00D8FF"/>

                                <Setter TargetName="Border"
                                        Property="BorderThickness"
                                        Value="1"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

        <Style x:Key="HeroOverlayButton"
       TargetType="Button">

            <Setter Property="Background"
            Value="Transparent"/>

            <Setter Property="BorderThickness"
            Value="0"/>

            <Setter Property="Cursor"
            Value="Hand"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="HoverBorder"
                        CornerRadius="10"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0">

                            <ContentPresenter/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                             Value="True">

                                <Setter TargetName="HoverBorder"
                                Property="Background"
                                Value="#1100D8FF"/>

                                <Setter TargetName="HoverBorder"
                                Property="BorderBrush"
                                Value="#33AAFFFF"/>

                                <Setter TargetName="HoverBorder"
                                Property="BorderThickness"
                                Value="1"/>

                            </Trigger>

                            <Trigger Property="IsPressed"
                             Value="True">

                                <Setter TargetName="HoverBorder"
                                Property="Background"
                                Value="#22FF44CC"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

        <Style x:Key="WindowControlButton"
       TargetType="Button">

            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Foreground" Value="#EAF1FF"/>
            <Setter Property="Background" Value="#15000000"/>
            <Setter Property="BorderBrush" Value="#336AAEFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="ChromeBorder"
                        CornerRadius="12"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">

                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                             Value="True">

                                <Setter TargetName="ChromeBorder"
                                Property="BorderBrush"
                                Value="#00D8FF"/>

                                <Setter TargetName="ChromeBorder"
                                Property="Background"
                                Value="#2200D8FF"/>

                            </Trigger>

                            <Trigger Property="IsPressed"
                             Value="True">

                                <Setter TargetName="ChromeBorder"
                                Property="Background"
                                Value="#4400D8FF"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

        <Style x:Key="CloseWindowButton"
       BasedOn="{StaticResource WindowControlButton}"
       TargetType="Button">

            <Setter Property="Background"
            Value="#331E0E12"/>

            <Setter Property="BorderBrush"
            Value="#AAFF4D6D"/>

        </Style>

    </Window.Resources>

    <Border Margin="8"
        CornerRadius="20"
        Background="#070E18">

        <Border.Effect>
            <DropShadowEffect BlurRadius="50"
                          ShadowDepth="0"
                          Color="#000000"
                          Opacity="0.6"/>
        </Border.Effect>

        <Border.BorderBrush>

            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,0">

                <GradientStop Color="#00D8FF"
                              Offset="0"/>

                <GradientStop Color="#FF44CC"
                              Offset="1"/>

            </LinearGradientBrush>

        </Border.BorderBrush>

        <Border.BorderThickness>2</Border.BorderThickness>

        <Grid>

            <!-- Dashboard Skin -->
            <Image Source="/Assets/UI/MainWindowBackground.png" Stretch="Fill"/>

            <!-- Dashboard Logo -->


            <Image Source="/Assets/UI/MainDashboardLogo.png"
                   Width="310"
                   Height="110"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                   Margin="55,45,0,0"/>

            <!-- Dashboard Hero Section -->
            <!-- HERO PANEL -->

            <Border Style="{StaticResource GlassPanel}"
                    Width="1100"
                    Height="600"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="370,180,0,0">

                <Grid>

                    <Image Source="/Assets/UI/HeroSection.png"
                           Stretch="Uniform"
                           Margin="20"/>

                    <!-- Open Keyboard Overlay -->
                    <Button Style="{StaticResource HeroOverlayButton}"
                            Width="275"
                            Height="54"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Margin="52,-15,0,0"
                            Click="OpenKeyboardWindowButton_Click"/>



                </Grid>

            </Border>


            <!-- Top Header Controls -->

            <ComboBox Style="{StaticResource GlassComboBox}"
                      Width="180"
                      Height="40"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top"
                      Margin="810,50,0,0"
                      ItemsSource="{Binding KeyboardLayoutOptions}"
                      SelectedItem="{Binding KeyboardLayout}"/>

            <ComboBox Style="{StaticResource GlassComboBox}"
                      Width="180"
                      Height="40"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top"
                      Margin="1010,50,0,0"
                      ItemsSource="{Binding ThemeOptions}"
                      SelectedItem="{Binding SelectedTheme}"/>

            <Button Width="130"
                    Height="40"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="1180,50,0,0"
                    Content="Calibration"
                    Click="OpenCalibrationButton_Click"/>

            <!-- Window Buttons -->


            <Border Width="1569"
                    Height="64"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="-20,-18,0,0"
                    CornerRadius="28,28,0,0"
                    Background="#22081428"
                    BorderBrush="#5500D8FF"
                    BorderThickness="0,0,0,1">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="18"
                          ShadowDepth="0"
                          Color="#00D8FF"
                          Opacity="0.25"/>
                </Border.Effect>

            </Border>

            <Button Style="{StaticResource WindowControlButtonStyle}"
                    Width="36"
                    Height="36"
                    Margin="1367,0,113,968"
                    Content="−"
                    FontSize="18"
                    Click="MinimizeButton_Click"/>

            <Button Style="{StaticResource WindowControlButtonStyle}"
                    Width="36"
                    Height="36"
                    Margin="1407,0,73,968"
                    Content="▢"
                    FontSize="16"
                    Click="MaximizeRestoreButton_Click"/>

            <Button Style="{StaticResource CloseWindowButton}"
                    Width="40"
                    Height="40"
                    Margin="1447,0,29,964"
                    Content="✕"
                    Click="CloseButton_Click"/>



            <!-- Sidebar -->

            <Border Style="{StaticResource GlassPanel}"
                    Width="300"
                    Height="620"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="45,180,0,0">

                <StackPanel Margin="20">

                    <Button Style="{StaticResource SidebarButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⌨" Foreground="#00D8FF" Margin="0,0,12,0"/>
                            <TextBlock Text="Keyboard"  Foreground="#DDEAFF"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎛" Foreground="#00D8FF" Margin="0,0,12,0"/>
                            <TextBlock Text="Mixer"  Foreground="#DDEAFF"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎵" Foreground="#00D8FF" Margin="0,0,12,0"/>
                            <TextBlock Text="Sound Library"  Foreground="#DDEAFF"/>
                        </StackPanel>
                    </Button>


                    <Button Style="{StaticResource SidebarButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎚" Foreground="#00D8FF" Margin="0,0,12,0"/>
                            <TextBlock Text="Effects"  Foreground="#DDEAFF"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" Foreground="#00D8FF" Margin="0,0,12,0"/>
                            <TextBlock Text="Analytics"  Foreground="#DDEAFF"/>
                        </StackPanel>
                    </Button>


                    <Button Style="{StaticResource SidebarButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" Foreground="#00D8FF" Margin="0,0,12,0"/>
                            <TextBlock Text="Settings"  Foreground="#DDEAFF"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

            </Border>

            <!-- Dynamic Cards -->

            <TextBlock Text="{Binding StatusText}"
               Width="260"
               TextWrapping="Wrap"
               Foreground="White"
               Margin="409,735,0,0"
               HorizontalAlignment="Left"
               VerticalAlignment="Top"/>

        </Grid>
    </Border>
</Window>