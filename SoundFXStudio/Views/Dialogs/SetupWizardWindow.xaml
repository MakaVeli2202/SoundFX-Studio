<Window x:Class="SoundFXStudio.Views.Dialogs.SetupWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Audio Setup Wizard"
        Width="920"
        Height="620"
        WindowStartupLocation="CenterScreen"
        Background="#050505"
        ResizeMode="NoResize"
        WindowStyle="None"
        Icon="/Assets/SoundFXStudioLogo.png">

    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#0D0D0D" />
        <SolidColorBrush x:Key="SecondaryPanelBrush" Color="#141414" />
        <SolidColorBrush x:Key="BorderBrushTheme" Color="#2B2B2B" />
        <SolidColorBrush x:Key="TextBrush" Color="#F5F7FB" />
        <SolidColorBrush x:Key="MutedBrush" Color="#A0A7B4" />
    </Window.Resources>

    <Grid Margin="20">
        <Border Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushTheme}"
                BorderThickness="1"
                CornerRadius="20"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Background="{StaticResource SecondaryPanelBrush}"
                    CornerRadius="16"
                        BorderBrush="#252525"
                        BorderThickness="1"
                    Padding="12"
                    Margin="0,0,0,14">
                    <Grid MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="44"
                                    Height="44"
                                    CornerRadius="12"
                                    Background="#0A0A0A"
                                    BorderBrush="#303030"
                                    BorderThickness="1"
                                    Padding="4"
                                    Margin="0,0,12,0">
                                <Image Source="/Assets/SoundFXStudioLogo.png" Stretch="Uniform" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="SoundFX Studio" FontSize="13" FontWeight="Bold" Foreground="{StaticResource MutedBrush}" />
                                <TextBlock Text="Audio setup wizard" FontSize="26" FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="✕"
                            Width="40"
                            Height="30"
                                VerticalAlignment="Top"
                                Background="#2A1118"
                                BorderBrush="#5F2336"
                                Click="CloseButton_Click" />
                    </Grid>
                </Border>

                <TextBlock Grid.Row="0"
                           Text="Pick the speakers and microphone you use, and we'll get SoundFX Studio ready to go."
                           Foreground="{StaticResource MutedBrush}"
                           Margin="0,54,0,14"
                           TextWrapping="Wrap" />

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.25*" />
                        <ColumnDefinition Width="0.95*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{StaticResource SecondaryPanelBrush}"
                            BorderBrush="{StaticResource BorderBrushTheme}"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="16"
                            Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Pick Your Devices" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,14" />

                            <TextBlock Text="🔊 Speakers (where you hear sounds)" Foreground="{StaticResource MutedBrush}" />
                            <ComboBox x:Name="OutputCombo" Margin="0,6,0,14" Height="34" DisplayMemberPath="Name" SelectedValuePath="Id" />

                            <TextBlock Text="🎙️ Microphone (your voice)" Foreground="{StaticResource MutedBrush}" />
                            <ComboBox x:Name="InputCombo" Margin="0,6,0,14" Height="34" DisplayMemberPath="Name" SelectedValuePath="Id" />

                            <TextBlock x:Name="StatusText" Margin="0,16,0,0" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Background="{StaticResource SecondaryPanelBrush}"
                            BorderBrush="{StaticResource BorderBrushTheme}"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="How It Works" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,14" />
                            <TextBlock Text="✓ Sounds play through your speakers" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,0,0,8" />
                            <TextBlock Text="✓ Your microphone is ready to use" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,0,0,8" />
                            <TextBlock Text="✓ Click keyboard buttons (or press F1-F12) to play sounds" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,0,0,16" />
                        </StackPanel>
                    </Border>
                </Grid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                    <Button Content="Open Windows Sound" Width="170" Margin="0,0,10,0" Click="OpenSound_Click" />
                    <Button Content="Auto-configure" Width="150" Margin="0,0,10,0" Click="AutoConfigure_Click" />
                    <Button Content="Finish" Width="110" IsDefault="True" Click="Finish_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>